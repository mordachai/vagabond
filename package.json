{
  "name": "vagabond",
  "version": "5.9.0",
  "description": "CSS compiler for the Vagabond system",
  "scripts": {
    "build": "sass src/scss/vagabond.scss css/vagabond.css --style=expanded --no-source-map",
    "watch": "sass src/scss/vagabond.scss css/vagabond.css --style=expanded --source-map --watch",
    "createSymlinks": "node src/create-symlinks.mjs",
    "pack": "node src/packs.mjs pack",
    "unpack": "node src/packs.mjs unpack"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "Asacolips",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "js-yaml": "^4.1.0",
    "sass": "^1.53.0"
  }
}
