    "levelFeatures": [
      {
        "level": 1,
        "name": "Spellstriker",
        "description": "<p>You gain the Gish Perk and can Cast Spells using Arcana. Spells: You learn 2 Spells, one of which must always be Ward. You learn 1 other Spell every 3 Magus Levels hereafter. Mana: Your Maximum Mana is equal to (2 × your Magus Level), and the highest amount of Mana you can spend to Cast a Spell is equal to (Reason + half your Magus Level, round up). You regain spent Mana when you Rest.</p>",
        "statBonusPoints": 0,
        "extraTraining": 0,
        "requiredSpells": [
          "Compendium.vagabond.spells.Item.L43XdoqLgQ8Wl6vM"
        ],
