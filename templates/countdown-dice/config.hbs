<form class="countdown-dice-config-form">
  {{! Name (wide) + Size letter buttons (narrow) — same row }}
  <div class="form-group form-row cd-name-size-row">
    <div class="form-field">
      <label for="dice-name" class="resource-label">{{localize 'VAGABOND.CountdownDice.Name'}}</label>
      <input
        type="text"
        id="dice-name"
        name="name"
        value="{{name}}"
        required
        placeholder="{{localize 'VAGABOND.CountdownDice.Name'}}"
      />
    </div>

    <div class="form-field">
      <label class="resource-label">{{localize 'VAGABOND.CountdownDice.Size'}}</label>
      <input type="hidden" name="size" value="{{size}}" />
      <div class="cd-size-row">
        {{#each sizeCards}}
        <button type="button" class="cd-size-btn {{#if this.selected}}is-selected{{/if}}"
                data-size="{{this.key}}" data-tooltip="{{this.label}}">{{this.key}}</button>
        {{/each}}
      </div>
    </div>
  </div>

  {{! Dice Type — image buttons, no labels }}
  <div class="form-group">
    <label class="resource-label">{{localize 'VAGABOND.CountdownDice.DiceType'}}</label>
    <input type="hidden" name="diceType" value="{{diceType}}" />
    <div class="cd-card-row">
      {{#each diceCards}}
      <button type="button" class="cd-card {{#if this.selected}}is-selected{{/if}}"
              data-dice="{{this.type}}" data-tooltip="{{this.type}}">
        <img class="cd-card-img" src="{{this.img}}" alt="{{this.type}}" />
      </button>
      {{/each}}
    </div>
  </div>

  {{! Permissions — who can see / roll this die }}
  <fieldset class="form-group cd-perms-section">
    <legend>{{localize "VAGABOND.ProgressClock.TabPermissions"}}</legend>
    {{> "systems/vagabond/templates/shared/permission-matrix.hbs"}}
  </fieldset>

  <footer class="form-footer">
    <button type="button" data-action="cancel">
      <i class="fas fa-times"></i> {{localize 'Cancel'}}
    </button>
    <button type="submit" class="default">
      <i class="fas fa-check"></i> {{#if isEdit}}{{localize 'Update'}}{{else}}{{localize 'Create'}}{{/if}}
    </button>
  </footer>
</form>
