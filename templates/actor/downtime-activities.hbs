<div class="downtime-container">
<div class="downtime-grid">
    {{!-- Rest Activity --}}
    <div class="activity-card">
        <div class="activity-header">
            <i class="fas fa-bed"></i> {{localize "VAGABOND.Downtime.Rest.Title"}}
            <span class="cost-badge">{{localize "VAGABOND.Downtime.Cost.OneShift"}}</span>
        </div>
        <div class="activity-content">
            <p>{{localize "VAGABOND.Downtime.Rest.Description"}}</p>
            <div class="input-group">
                <label>{{localize "VAGABOND.Downtime.Rest.LodgingLabel"}}</label>
                <select name="lodgingType">
                    <option value="none">{{localize "VAGABOND.Downtime.Lodging.none"}}</option>
                    <option value="horrible">{{localize "VAGABOND.Downtime.Lodging.horrible"}}</option>
                    <option value="poor">{{localize "VAGABOND.Downtime.Lodging.poor"}}</option>
                    <option value="modest">{{localize "VAGABOND.Downtime.Lodging.modest"}}</option>
                    <option value="comfortable">{{localize "VAGABOND.Downtime.Lodging.comfortable"}}</option>
                    <option value="luxury">{{localize "VAGABOND.Downtime.Lodging.luxury"}}</option>
                    <option value="opulent">{{localize "VAGABOND.Downtime.Lodging.opulent"}}</option>
                </select>
            </div>
        </div>
        <button type="button" class="downtime-btn" data-action="processRest">
            <i class="fas fa-bed"></i> {{localize "VAGABOND.Downtime.Rest.Title"}}
        </button>
    </div>

    {{!-- Breather Activity --}}
    <div class="activity-card">
        <div class="activity-header">
            <i class="fas fa-heart"></i> {{localize "VAGABOND.Downtime.Breather.Title"}}
            <span class="cost-badge">{{localize "VAGABOND.Downtime.Cost.Free"}}</span>
        </div>
        <div class="activity-content">
            <p>{{localize "VAGABOND.Downtime.Breather.Description"}}</p>
            <p><strong>{{localize "VAGABOND.Downtime.Breather.Effect" stat=(localize (lookup config.stats "might")) value=actor.system.stats.might.value}}</strong></p>
        </div>
        <button type="button" class="downtime-btn" data-action="processBreather">
            <i class="fas fa-heart"></i> {{localize "VAGABOND.Downtime.Breather.Button"}}
        </button>
    </div>

    {{!-- Craft Activity --}}
    <div class="activity-card">
        <div class="activity-header">
            <i class="fas fa-hammer"></i> {{localize "VAGABOND.Downtime.Craft.Title"}}
            <span class="cost-badge">{{localize "VAGABOND.Downtime.Cost.OneShift"}}</span>
        </div>
        <div class="activity-content">
            <p>{{localize "VAGABOND.Downtime.Craft.Description"}}</p>
            <div class="input-group">
                <label>{{localize "VAGABOND.Downtime.Craft.DifficultyLabel"}}</label>
                <select name="craftDiff">
                    <option value="1">{{localize "VAGABOND.Downtime.CraftDifficulty.tier1"}}</option>
                    <option value="20">{{localize "VAGABOND.Downtime.CraftDifficulty.tier2"}}</option>
                    <option value="50">{{localize "VAGABOND.Downtime.CraftDifficulty.tier3"}}</option>
                    <option value="250">{{localize "VAGABOND.Downtime.CraftDifficulty.tier4"}}</option>
                    <option value="500">{{localize "VAGABOND.Downtime.CraftDifficulty.tier5"}}</option>
                    <option value="750">{{localize "VAGABOND.Downtime.CraftDifficulty.tier6"}}</option>
                    <option value="1000">{{localize "VAGABOND.Downtime.CraftDifficulty.tier7"}}</option>
                </select>
            </div>
        </div>
        <button type="button" class="downtime-btn" data-action="processCraft">
            <i class="fas fa-tools"></i> {{localize "VAGABOND.Downtime.Craft.Button"}}
        </button>
    </div>

    {{!-- Forage Activity --}}
    <div class="activity-card">
        <div class="activity-header">
            <i class="fas fa-leaf"></i> {{localize "VAGABOND.Downtime.Forage.Title"}}
            <span class="cost-badge">{{localize "VAGABOND.Downtime.Cost.OneShift"}}</span>
        </div>
        <div class="activity-content">
            <p>{{localize "VAGABOND.Downtime.Forage.Description"}}</p>
            <div class="input-group">
                <label>{{localize "VAGABOND.Downtime.Forage.TargetLabel"}}</label>
                <select name="forageType">
                    <option value="food">{{localize "VAGABOND.Downtime.ForageType.food"}}</option>
                    <option value="mats">{{localize "VAGABOND.Downtime.ForageType.mats"}}</option>
                </select>
            </div>
        </div>
        <button type="button" class="downtime-btn" data-action="processForage">
            <i class="fas fa-search"></i> {{localize "VAGABOND.Downtime.Forage.Button"}}
        </button>
    </div>

    {{!-- Hunt Activity --}}
    <div class="activity-card">
        <div class="activity-header">
            <i class="fas fa-paw"></i> {{localize "VAGABOND.Downtime.Hunt.Title"}}
            <span class="cost-badge">{{localize "VAGABOND.Downtime.Cost.OneShift"}}</span>
        </div>
        <div class="activity-content">
            <p>{{localize "VAGABOND.Downtime.Hunt.Description"}}</p>
        </div>
        <button type="button" class="downtime-btn" data-action="processHunt">
            <i class="fas fa-bow-arrow"></i> {{localize "VAGABOND.Downtime.Hunt.Button"}}
        </button>
    </div>

    {{!-- Study Activity --}}
    <div class="activity-card">
        <div class="activity-header">
            <i class="fas fa-book-open"></i> {{localize "VAGABOND.Downtime.Study.Title"}}
            <span class="cost-badge">{{localize "VAGABOND.Downtime.Cost.OneShift"}}</span>
        </div>
        <div class="activity-content">
            <p>{{localize "VAGABOND.Downtime.Study.Description"}}</p>
            <div class="input-group" style="background: rgba(0,0,0,0.1); padding: 5px; border-radius: 4px;">
                <label>{{localize "VAGABOND.Downtime.Study.CurrentDice" value=studiedDice}}</label>
            </div>
        </div>
        <button type="button" class="downtime-btn" data-action="processStudy">
            <i class="fas fa-graduation-cap"></i> {{localize "VAGABOND.Downtime.Study.Button"}}
        </button>
    </div>
</div>

{{!-- Footer Buttons --}}
<footer class="downtime-footer">
    <button type="button" class="downtime-footer-btn cancel-btn" data-action="cancelDowntime">
        <i class="fas fa-times"></i> {{localize "VAGABOND.Downtime.Cancel"}}
    </button>
    <button type="button" class="downtime-footer-btn done-btn" data-action="doneDowntime">
        <i class="fas fa-check"></i> {{localize "VAGABOND.Downtime.Done"}}
    </button>
</footer>
</div>
