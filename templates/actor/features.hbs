{{! Features Tab }}
<section
  class='tab features scrollable {{tab.cssClass}}'
  data-group='primary'
  data-tab='features'
>
  <section class='grid grid-3col'>
    {{! Left column: Stats }}
    <aside class='sidebar'>
      <h3>Stats</h3>
      <div class='abilities flexcol'>
        {{#each system.abilities as |ability key|}}
          <div class='ability flexrow flex-group-center'>
            <label
              class='resource-label rollable flexlarge align-left'
              data-action='roll'
              data-roll='d20'
              data-label='{{localize (lookup @root.config.abilities key)}} Check'
            >{{localize (lookup @root.config.abilities key)}}</label>
            <input
              type='text'
              name='system.abilities.{{key}}.value'
              value='{{ability.value}}'
              class="ability-score"
              data-dtype='Number'
            />
          </div>
        {{/each}}
      </div>

      {{! Features Section }}
      <h3 style='margin-top: 20px;'>Features</h3>
      <ul class='features-list' style='list-style: none; padding-left: 0;'>
        {{#each features as |feature id|}}
          <li class='feature' style='margin-bottom: 10px;'>
            <strong>{{feature.name}}</strong>
            {{#if feature.description}}
              <div style='margin-top: 5px; font-size: 12px; color: var(--vagabond-c-tan);'>{{feature.description}}</div>
            {{/if}}
          </li>
        {{else}}
          <li class='feature'>No features yet. Features are granted by your class as you level up.</li>
        {{/each}}
      </ul>
    </aside>

    {{! Middle column: Saves and Skills }}
    <section class='main grid-span-1'>
      {{! Saves Section - Horizontal layout with border }}
      <div class='saves' style='margin-bottom: 20px; border: 2px solid #333; padding: 10px;'>
        <h3 style='margin-top: 0; text-align: center;'>SAVES</h3>
        <div class='saves-row flexrow' style='justify-content: space-around;'>
          {{#each system.saves as |save key|}}
            <div class='save flexcol align-center' style='flex: 1; text-align: center;'>
              <label
                class='resource-label rollable'
                data-action='roll'
                data-roll='d20'
                data-label='{{save.label}} Save (Difficulty {{save.difficulty}})'
                data-tooltip='{{save.description}}'
                style='cursor: pointer; margin-bottom: 5px;'
              >{{save.label}}</label>
              <span class='save-difficulty' style='font-weight: bold; font-size: 18px;'>[{{save.difficulty}}]</span>
            </div>
          {{/each}}
        </div>
      </div>

      {{! Skills Section }}
      <div class='skills flexcol'>
        <h3>Skills</h3>
        {{#each system.skills as |skill key|}}
          <div class='skill flexrow flex-group-center' style='margin-bottom: 5px;'>
            <input
              type='checkbox'
              name='system.skills.{{key}}.trained'
              {{#if skill.trained}}checked{{/if}}
              style='margin-right: 10px;'
            />
            <label
              class='resource-label rollable flexlarge align-left'
              data-action='roll'
              data-roll='d20'
              data-label='{{skill.label}} (Difficulty {{skill.difficulty}})'
              style='cursor: pointer;'
            >{{skill.label}} {{#if skill.trained}}(Trained){{/if}}</label>
            <span class='skill-difficulty' style='margin-left: auto; font-weight: bold;'>{{skill.difficulty}}</span>
          </div>
        {{/each}}
      </div>
    </section>

    {{! Right column: Attacks and Perks }}
    <section class='attacks-section grid-span-1'>
      {{! Weapon Skills / Attacks Section }}
      <div class='weapon-skills flexcol'>
        <h3>Attacks</h3>
        {{#each system.weaponSkills as |weaponSkill key|}}
          <div class='weapon-skill flexrow flex-group-center' style='margin-bottom: 5px;'>
            <input
              type='checkbox'
              name='system.weaponSkills.{{key}}.trained'
              {{#if weaponSkill.trained}}checked{{/if}}
              style='margin-right: 10px;'
            />
            <label
              class='resource-label rollable flexlarge align-left'
              data-action='roll'
              data-roll='d20'
              data-label='{{weaponSkill.label}} (Difficulty {{weaponSkill.difficulty}})'
              style='cursor: pointer;'
            >{{weaponSkill.label}} {{#if weaponSkill.trained}}(Trained){{/if}}</label>
            <span class='weapon-skill-difficulty' style='margin-left: auto; font-weight: bold;'>{{weaponSkill.difficulty}}</span>
          </div>
        {{/each}}

        {{! Equipped Weapons }}
        {{#each weapons as |weapon|}}
          {{#if weapon.system.equipped}}
            <div class='equipped-weapon flexrow flex-group-center' style='margin-bottom: 5px; margin-top: 10px; padding: 5px; background-color: rgba(0,0,0,0.1); border-radius: 3px;'>
              <label
                class='resource-label rollable flexlarge align-left'
                data-action='rollWeapon'
                data-item-id='{{weapon._id}}'
                style='cursor: pointer;'
                title='{{weapon.system.propertiesDisplay}}'
              >{{weapon.name}} ({{weapon.system.currentDamage}})</label>
              <span class='weapon-info' style='margin-left: auto; font-size: 0.9em;'>
                {{weapon.system.rangeDisplay}}
                {{#if (eq weapon.system.equipmentState 'oneHand')}}
                  <i class='fas fa-hand-fist' title='One-Handed'></i>
                {{else if (eq weapon.system.equipmentState 'twoHands')}}
                  <i class='fas fa-hands' title='Two-Handed'></i>
                {{/if}}
              </span>
            </div>
          {{/if}}
        {{/each}}
      </div>

      {{! Perks Section }}
      <div class='perks-section flexcol' style='margin-top: 20px;'>
        <h3>Perks</h3>
        <ol class='perks-list'>
          {{#each enrichedPerks as |perk|}}
            <li class='perk-card' data-item-id='{{perk._id}}' data-tooltip='Click to view, Right-click to remove'>
              <div class='perk-header flexrow'>
                <h4 class='perk-name'>{{perk.name}}</h4>
              </div>
              {{#if perk.prerequisites}}
                <div class='perk-prerequisites'>{{perk.prerequisites}}</div>
              {{/if}}
              {{#if perk.enrichedDescription}}
                <div class='perk-description'>{{{perk.enrichedDescription}}}</div>
              {{/if}}
            </li>
          {{else}}
            <li class='no-perks' style='font-style: italic; color: var(--vagabond-c-tan); list-style: none;'>No perks yet. Drag perks from the Items directory.</li>
          {{/each}}
        </ol>
      </div>
    </section>
  </section>
</section>
