{{! Features Tab }}
<section
  class='tab features scrollable {{tab.cssClass}}'
  data-group='primary'
  data-tab='features'
>

  {{! Inventory Section }}
  <section class='panel-section inventory-section'>
    <h2 class='panel-title'>Inventory</h2>

    {{! Wealth Section }}
    <div class='wealth-section'>
      <div class='currency-row flexrow'>
        <h3 class='section-title'>Wealth:</h3>
        <div class='currency-field'>
          <label class='resource-label'>Gold</label>
          <input
            type='text'
            name='system.currency.gold'
            value='{{system.currency.gold}}'
            data-dtype='Number'
            {{#unless @root.editable}}disabled{{/unless}}
          />
        </div>
        <div class='currency-field'>
          <label class='resource-label'>Silver</label>
          <input
            type='text'
            name='system.currency.silver'
            value='{{system.currency.silver}}'
            data-dtype='Number'
            {{#unless @root.editable}}disabled{{/unless}}
          />
        </div>
        <div class='currency-field'>
          <label class='resource-label'>Copper</label>
          <input
            type='text'
            name='system.currency.copper'
            value='{{system.currency.copper}}'
            data-dtype='Number'
            {{#unless @root.editable}}disabled{{/unless}}
          />
        </div>
      </div>
    </div>

    {{! Inventory Slots Section }}
    <div class='inventory-slots-section'>
      <div class='slots-info flexrow'>
        <div class='slot-field'>
          <label class='resource-label'>Slots:</label>
          <span class='slot-value'>{{system.inventory.occupiedSlots}} / {{system.inventory.maxSlots}}</span>
        </div>
        {{#if (gt system.inventory.occupiedSlots system.inventory.maxSlots)}}
          <div class='slot-warning'>
            <i class='fas fa-exclamation-triangle'></i>
            <span>Overloaded!</span>
          </div>
        {{/if}}
        {{#if @root.editable}}
          <button
            type='button'
            class='auto-arrange-button'
            data-action='autoArrangeInventory'
            data-tooltip='Automatically arrange items in inventory grid'
          >
            <i class='fas fa-sort'></i> Auto-Arrange
          </button>
        {{/if}}
      </div>
    </div>

    {{! Visual Inventory Grid - 5 rows × 4 columns }}
    <div class='inventory-grid-container'>
      <div class='inventory-grid' data-max-slots='{{system.inventory.maxSlots}}'>
        {{! Render inventory items }}
        {{#each inventoryItems as |itemData|}}
          {{! Inventory Card - Visual slot-based item card }}
          <div
            class='inventory-card {{#if itemData.equipped}}equipped{{/if}}'
            data-item-id='{{itemData.item._id}}'
            data-item-slots='{{itemData.item.system.slots}}'
            data-item-type='{{itemData.item.type}}'
            data-grid-position='{{itemData.gridPosition}}'
            style='grid-column: span {{itemData.item.system.slots}};'
            draggable='true'
          >
            <div class='inventory-card-content'>
              {{! Top row: Weapon skill icon and item name }}
              <div class='inventory-card-header'>
                {{#if (eq itemData.item.type 'equipment')}}
                  {{#if (eq itemData.item.system.equipmentType 'weapon')}}
                    {{! Weapon skill icon with metal color }}
                    <div
                      class='weapon-skill-icon'
                      style='background-color: {{itemData.metalColor}};'
                      data-tooltip='{{itemData.item.system.weaponSkill}}'
                    >
                      <img src='{{itemData.weaponSkillIcon}}' alt='{{itemData.item.system.weaponSkill}}' />
                    </div>
                  {{else if (eq itemData.item.system.equipmentType 'armor')}}
                    {{! Armor icon }}
                    <div class='armor-icon' data-tooltip='Armor'>
                      <i class='fas fa-shield-halved'></i>
                    </div>
                  {{else}}
                    {{! Generic gear icon }}
                    <div class='gear-icon' data-tooltip='Gear'>
                      <i class='fas fa-box'></i>
                    </div>
                  {{/if}}
                {{else}}
                  {{! Other item types }}
                  <div class='gear-icon' data-tooltip='{{itemData.item.type}}'>
                    <i class='fas fa-box'></i>
                  </div>
                {{/if}}

                <div class='item-name-display' data-tooltip='{{itemData.item.name}}'>{{itemData.item.name}}</div>
              </div>

              {{! Bottom row: Damage, Grip, Range, Cost }}
              <div class='inventory-card-stats'>
                {{#if (or (eq itemData.item.type 'equipment') (eq itemData.item.type 'weapon'))}}
                  {{#if (or (eq itemData.item.system.equipmentType 'weapon') (eq itemData.item.type 'weapon'))}}
                    {{! Damage display with damage type icon }}
                    <div class='stat-group damage-group'>
                      <span class='stat-label'>{{itemData.item.system.currentDamage}}</span>
                      {{#if itemData.damageTypeIcon}}
                        <img class='damage-type-icon' src='{{itemData.damageTypeIcon}}' alt='{{itemData.item.system.damageType}}' data-tooltip='{{itemData.item.system.damageType}}' />
                      {{/if}}
                      {{#if itemData.item.system.grip}}
                        <span class='stat-value grip-display' data-tooltip='{{itemData.item.system.gripDisplay}}'>{{itemData.item.system.grip}}</span>
                      {{/if}}
                    </div>

                    {{! Range and Cost }}
                    <div class='stat-group range-cost-group'>
                      {{#if itemData.item.system.rangeAbbr}}
                        <span class='stat-value range-display' data-tooltip='{{itemData.item.system.rangeDisplay}}'>{{itemData.item.system.rangeAbbr}}</span>
                      {{/if}}
                      <span class='stat-value cost-display'>s{{itemData.item.system.costDisplay}}</span>
                    </div>
                  {{else if (eq itemData.item.system.equipmentType 'armor')}}
                    {{! Armor stats }}
                    <div class='stat-group armor-stats'>
                      <span class='stat-label'>Rating {{itemData.item.system.finalRating}}</span>
                      <span class='stat-value cost-display'>s{{itemData.item.system.costDisplay}}</span>
                    </div>
                  {{else}}
                    {{! Generic gear stats }}
                    <div class='stat-group gear-stats'>
                      {{#if itemData.item.system.quantity}}
                        <span class='stat-label'>Qty: {{itemData.item.system.quantity}}</span>
                      {{/if}}
                      <span class='stat-value cost-display'>s{{itemData.item.system.costDisplay}}</span>
                    </div>
                  {{/if}}
                {{else}}
                  {{! Fallback for other item types }}
                  <div class='stat-group generic-stats'>
                    <span class='stat-value cost-display'>s{{itemData.item.system.costDisplay}}</span>
                  </div>
                {{/if}}
              </div>
            </div>

            {{! Equipped indicator (using internal box-shadow) }}
            {{#if itemData.equipped}}
              <div class='equipped-indicator'></div>
            {{/if}}
          </div>
        {{/each}}

        {{! Render empty slots }}
        {{#each emptySlots as |slot|}}
          <div
            class='inventory-slot empty-slot {{#if slot.unavailable}}unavailable{{/if}}'
            data-slot-index='{{slot.index}}'
            data-droppable='true'
          >
            <div class='slot-number'>{{slot.displayNumber}}</div>
          </div>
        {{/each}}
      </div>
    </div>
  </section>
  
  {{! Features & Perks Section }}
  <section class='panel-section features-perks-section'>
    {{!-- <h2 class='panel-title'>Features & Perks</h2> --}}

    <div class='grid grid-2col'>
      {{! Left Column: Features }}
      <div class='features-column grid-span-1'>
        <h2>Features</h2>
        <ul class='features-list'>
          {{#each features as |feature id|}}
            <li class='feature accordion-item collapsed' data-item-id='{{feature._id}}'>
              <div class='feature-header accordion-header clickable' data-action='toggleFeature' data-feature-id='{{feature._id}}'>
                <h4 class='feature-name'>{{feature.name}}</h4>
              </div>
              {{#if feature.description}}
                <div class='feature-description accordion-content' data-feature-id='{{feature._id}}'>{{{feature.description}}}</div>
              {{/if}}
            </li>
          {{else}}
            <li class='no-features'>No features yet. Features are granted by your class as you level up.</li>
          {{/each}}
        </ul>
      </div>

      {{! Right Column: Perks }}
      <div class='perks-column grid-span-1'>
        <h2>Perks</h2>
        <ul class='perks-list'>
          {{#each enrichedPerks as |perk|}}
            <li class='perk-card accordion-item collapsed' data-item-id='{{perk._id}}'>
              <div class='perk-header accordion-header clickable' data-action='togglePerk' data-perk-id='{{perk._id}}'>
                <h4 class='perk-name'>{{perk.name}}</h4>
              </div>
              <div class='perk-content accordion-content' data-perk-id='{{perk._id}}'>
                {{#if perk.prerequisites}}
                  <div class='perk-prerequisites'>{{perk.prerequisites}}</div>
                {{/if}}
                {{#if perk.enrichedDescription}}
                  <div class='perk-description'>{{{perk.enrichedDescription}}}</div>
                {{/if}}
              </div>
            </li>
          {{else}}
            <li class='no-perks'>No perks yet. Drag perks from the Items directory.</li>
          {{/each}}
        </ul>
      </div>
    </div>
  </section>

</section>
