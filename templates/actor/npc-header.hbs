{{! NPC Sheet Header }}
<header class='npc-header'>
  {{! Lock/Unlock Toggle }}
  <div class='npc-lock-toggle'>
    <button
      type='button'
      data-action='toggleLock'
      class='npc-lock-button {{#if system.locked}}locked{{else}}unlocked{{/if}}'
      data-tooltip='{{#if system.locked}}Click to unlock and edit{{else}}Click to lock for play{{/if}}'
    >
      <i class='fas {{#if system.locked}}fa-lock{{else}}fa-lock-open{{/if}}'></i>
      {{#if system.locked}}Locked{{else}}Unlocked{{/if}}
    </button>
  </div>

  {{! Main Row: Image + Info }}
  <div class='npc-top-section'>
    {{! Left Column: Character Image }}
    <div class='npc-image-container'>
      <img
        class='npc-profile-img'
        src='{{actor.img}}'
        data-edit='img'
        data-action='onEditImage'
        data-tooltip='{{actor.name}}'
        width='120'
        height='120'
      />
    </div>

    {{! Right Column: Name, Size, Being Type }}
    <div class='npc-info-column'>
      {{! Name Row }}
      <div class='npc-name-row'>
        <input
          name='name'
          type='text'
          value='{{actor.name}}'
          placeholder='{{#unless system.locked}}NPC Name{{/unless}}'
          class='npc-name-input'
          {{#if system.locked}}readonly{{/if}}
        />
      </div>

      {{! Size and Being Type Row }}
      <div class='npc-type-row'>
        <select
          name='system.size'
          class='npc-size-select'
          data-dtype='String'
          {{#if system.locked}}disabled{{/if}}
        >
          <option value='tiny' {{#if (eq system.size 'tiny')}}selected{{/if}}>Tiny</option>
          <option value='small' {{#if (eq system.size 'small')}}selected{{/if}}>Small</option>
          <option value='medium' {{#if (eq system.size 'medium')}}selected{{/if}}>Medium</option>
          <option value='large' {{#if (eq system.size 'large')}}selected{{/if}}>Large</option>
          <option value='huge' {{#if (eq system.size 'huge')}}selected{{/if}}>Huge</option>
          <option value='gargantuan' {{#if (eq system.size 'gargantuan')}}selected{{/if}}>Gargantuan</option>
        </select>

        <select
          name='system.beingType'
          class='npc-being-select'
          data-dtype='String'
          {{#if system.locked}}disabled{{/if}}
        >
          <option value='Humanlike' {{#if (eq system.beingType 'Humanlike')}}selected{{/if}}>Humanlike</option>
          <option value='Fae' {{#if (eq system.beingType 'Fae')}}selected{{/if}}>Fae</option>
          <option value='Cryptid' {{#if (eq system.beingType 'Cryptid')}}selected{{/if}}>Cryptid</option>
          <option value='Artificials' {{#if (eq system.beingType 'Artificials')}}selected{{/if}}>Artificials</option>
          <option value='Beasts' {{#if (eq system.beingType 'Beasts')}}selected{{/if}}>Beasts</option>
          <option value='Outers' {{#if (eq system.beingType 'Outers')}}selected{{/if}}>Outers</option>
          <option value='Primordials' {{#if (eq system.beingType 'Primordials')}}selected{{/if}}>Primordials</option>
          <option value='Undead' {{#if (eq system.beingType 'Undead')}}selected{{/if}}>Undead</option>
        </select>
      </div>
    </div>
  </div>

  {{! NPC Stats Row }}
  <div class='npc-stats-row'>
    {{! HD }}
    <div class='npc-stat-field'>
      <label class='npc-field-label'>HD</label>
      <input
        type='text'
        name='system.hd'
        value='{{system.hd}}'
        data-dtype='Number'
        class='npc-field-input'
        placeholder='{{#unless system.locked}}1{{/unless}}'
        {{#if system.locked}}readonly{{/if}}
      />
    </div>

    {{! HP - Current / Max format }}
    <div class='npc-stat-field'>
      <label class='npc-field-label'>HP</label>
      <div class='npc-hp-display'>
        <input
          type='text'
          name='system.health.value'
          value='{{system.health.value}}'
          data-dtype='Number'
          class='npc-hp-current'
          placeholder='{{#unless system.locked}}10{{/unless}}'
        />
        <span class='npc-hp-separator'>/</span>
        <span class='npc-hp-max'>{{system.health.max}}</span>
      </div>
    </div>

    {{! Morale }}
    <div class='npc-stat-field'>
      <label class='npc-field-label'>Morale</label>
      <input
        type='text'
        name='system.morale'
        value='{{system.morale}}'
        data-dtype='Number'
        class='npc-field-input'
        placeholder='{{#unless system.locked}}—{{/unless}}'
        {{#if system.locked}}readonly{{/if}}
      />
    </div>

    {{! Appearing }}
    <div class='npc-stat-field'>
      <label class='npc-field-label'>Appearing</label>
      {{#if system.locked}}
        <div class='npc-field-display'>{{{enrichedAppearing}}}</div>
      {{else}}
        <input
          type='text'
          name='system.appearing'
          value='{{system.appearing}}'
          data-dtype='String'
          class='npc-field-input'
          placeholder='d6 or 2d8'
        />
      {{/if}}
    </div>

    {{! Speed }}
    <div class='npc-stat-field'>
      <label class='npc-field-label'>Speed</label>
      <input
        type='text'
        name='system.speed'
        value='{{system.speed}}'
        data-dtype='Number'
        class='npc-field-input'
        placeholder='{{#unless system.locked}}30{{/unless}}'
        {{#if system.locked}}readonly{{/if}}
      />
    </div>

    {{! Senses }}
    <div class='npc-stat-field npc-senses-field'>
      <label class='npc-field-label'>Senses</label>
      <input
        type='text'
        name='system.senses'
        value='{{system.senses}}'
        data-dtype='String'
        class='npc-field-input'
        placeholder='{{#unless system.locked}}Darkvision 60 ft{{/unless}}'
        {{#if system.locked}}readonly{{/if}}
      />
    </div>
  </div>
</header>
