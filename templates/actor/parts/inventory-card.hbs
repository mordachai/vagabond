{{! Inventory Card - Each item is a separate instance }}
<div
  class='inventory-card draggable
         {{#if equipped}}equipped{{/if}}
         {{#if isSlotZero}}slot-zero{{/if}}'
  data-item-id='{{item._id}}'
  data-uuid='{{item.uuid}}'
  data-item-slots='{{item.system.slots}}'
  data-item-type='{{item.type}}'
  data-grid-position='{{gridPosition}}'
  data-is-slot-zero='{{isSlotZero}}'
  data-display-number='{{displayNumber}}'
  style='grid-column: span {{#if (eq totalSlots 0)}}1{{else}}{{totalSlots}}{{/if}};'
  draggable='true'
>
  <img src='{{item.img}}' alt='{{item.name}}' class='item-image' />
  <div class='item-name-display'>{{item.name}}</div>
  {{#if usesPips.length}}
    <div class='item-uses-pips'>
      {{#each usesPips as |pip|}}
        <i
          class='fa-solid fa-circle uses-pip {{#if pip.filled}}filled{{else}}empty{{/if}}'
          data-action='usePip'
          data-item-uuid='{{../item.uuid}}'
          data-pip-index='{{pip.index}}'
        ></i>
      {{/each}}
    </div>
  {{/if}}
  {{#if requiresBound}}
    <div class='bound-marker'>
      {{#if bound}}
        <i class='fa-solid fa-diamond bound'></i>
      {{else}}
        <i class='fa-solid fa-diamond unbound'></i>
      {{/if}}
    </div>
  {{/if}}
</div>
