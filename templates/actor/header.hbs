{{! Sheet Header }}
<header class='sheet-header'>
  {{! Character Image Container }}
  <div class='char-image-container'>
    <img
      class='profile-img'
      src='{{actor.img}}'
      data-edit='img'
      data-action='onEditImage'
      data-tooltip='{{actor.name}}'
      width='180'
      height='180'
    />

    {{! Armor Info Overlay (Left side) }}
    <div class='armor-overlay'>
      <div class='armor-value'>{{system.armor}}</div>
      <div class='armor-type'>{{equippedArmorType}}</div>
    </div>

    {{! Fatigue Overlay (Bottom) }}
    <div class='fatigue-overlay'>
      <div class='fatigue-checkboxes'>
        {{#each fatigueBoxes as |box index|}}
          <i
            class='fas fa-skull fatigue-skull {{#if box.checked}}fatigue-active{{else}}fatigue-inactive{{/if}}'
            data-index='{{index}}'
            data-tooltip='Fatigue Level {{box.level}}'
          ></i>
        {{/each}}
      </div>
    </div>
  </div>

  {{! Hit Points (Below image) }}
  <div class='hp-display'>
    <i class='fas fa-heart hp-icon'></i>
    <input
      type='text'
      name='system.health.value'
      value='{{system.health.value}}'
      data-dtype='Number'
      class='hp-current'
    />
    <span class='hp-separator'>/</span>
    <span class='hp-max'>{{system.health.max}}</span>
  </div>

  <div class='header-fields'>
    {{! First Row: Level Up and XP - Aligned Right }}
    <div class='xp-level-row'>
      {{! Level Up Button }}
      {{#if (lt system.attributes.level.value 10)}}
        <button
          type='button'
          data-action='levelUp'
          data-tooltip='Level Up'
          class='btn-sm'
        >
          <i class='fas fa-level-up-alt'></i>
        </button>
      {{/if}}

      {{! XP Field with inline label }}
      <div class='xp-field'>
        <label class='resource-label'>{{localize 'VAGABOND.Actor.Character.FIELDS.attributes.xp.label'}}</label>
        <input
          type='text'
          name='system.attributes.xp'
          value='{{system.attributes.xp}}'
          data-dtype='Number'
          class='xp-input'
        />
      </div>
    </div>

    {{! Second Row: Character Name - Aligned Left }}
    <div class='name-row'>
      <input
        name='name'
        type='text'
        value='{{actor.name}}'
        placeholder='Character Name'
        class='character-name-input'
      />
    </div>

    {{! Third Row: Level, Ancestry, Class }}
    <div class='character-info-row'>
      <span>
        Level
        <input
          type='text'
          name='system.attributes.level.value'
          value='{{system.attributes.level.value}}'
          data-dtype='Number'
          class='level-input'
        />,
        {{#if system.ancestryData}}
          <span class='ancestry-name clickable-link' data-item-id='{{system.ancestryData.id}}' data-action='viewAncestry' data-tooltip='Click to view, Right-click to remove'>{{system.ancestryData.name}}</span>
        {{else}}
          <span class='text-faint'>Unknown Ancestry</span>
        {{/if}}
        {{#if system.classData}}
          <span class='class-name clickable-link' data-item-id='{{system.classData.id}}' data-action='viewClass' data-tooltip='Click to view, Right-click to remove'>{{system.classData.name}}</span>
        {{else}}
          <span class='text-faint'>No Class</span>
        {{/if}}
      </span>
    </div>

    {{! Fourth Row: Being Type and Size }}
    <div class='size-type-row'>
      <span>
        (
        <select
          name='system.attributes.beingType'
          class='being-type-select'
          data-dtype='String'
          title='Override being type (leave blank to use ancestry default)'
        >
          <option value=''>{{#if system.ancestryData.name}}{{system.ancestryData.beingType}} (from ancestry){{else}}Humanlike (default){{/if}}</option>
          <option value='Humanlike' {{#if (eq system.attributes.beingType 'Humanlike')}}selected{{/if}}>Humanlike</option>
          <option value='Fae' {{#if (eq system.attributes.beingType 'Fae')}}selected{{/if}}>Fae</option>
          <option value='Cryptid' {{#if (eq system.attributes.beingType 'Cryptid')}}selected{{/if}}>Cryptid</option>
          <option value='Artificials' {{#if (eq system.attributes.beingType 'Artificials')}}selected{{/if}}>Artificials</option>
          <option value='Beasts' {{#if (eq system.attributes.beingType 'Beasts')}}selected{{/if}}>Beasts</option>
          <option value='Outers' {{#if (eq system.attributes.beingType 'Outers')}}selected{{/if}}>Outers</option>
          <option value='Primordials' {{#if (eq system.attributes.beingType 'Primordials')}}selected{{/if}}>Primordials</option>
          <option value='Undead' {{#if (eq system.attributes.beingType 'Undead')}}selected{{/if}}>Undead</option>
        </select>,
        <select
          name='system.attributes.size'
          class='size-select'
          data-dtype='String'
          title='Override size (leave blank to use ancestry default)'
        >
          <option value=''>{{#if system.ancestryData.name}}{{localize (lookup config.sizes system.ancestryData.size)}} (from ancestry){{else}}{{localize "VAGABOND.Sizes.medium"}} (default){{/if}}</option>
          <option value='small' {{#if (eq system.attributes.size 'small')}}selected{{/if}}>{{localize "VAGABOND.Sizes.small"}}</option>
          <option value='medium' {{#if (eq system.attributes.size 'medium')}}selected{{/if}}>{{localize "VAGABOND.Sizes.medium"}}</option>
          <option value='large' {{#if (eq system.attributes.size 'large')}}selected{{/if}}>{{localize "VAGABOND.Sizes.large"}}</option>
          <option value='huge' {{#if (eq system.attributes.size 'huge')}}selected{{/if}}>{{localize "VAGABOND.Sizes.huge"}}</option>
          <option value='giant' {{#if (eq system.attributes.size 'giant')}}selected{{/if}}>{{localize "VAGABOND.Sizes.giant"}}</option>
          <option value='colossal' {{#if (eq system.attributes.size 'colossal')}}selected{{/if}}>{{localize "VAGABOND.Sizes.colossal"}}</option>
        </select>
        size)
      </span>
    </div>
  </div>
</header>
