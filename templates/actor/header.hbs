{{! Sheet Header }}
<header class='sheet-header'>
  <img
    class='profile-img'
    src='{{actor.img}}'
    data-edit='img'
    data-action='onEditImage'
    data-tooltip='{{actor.name}}'
    height='100'
    width='100'
  />
  <div class='header-fields'>
    {{! Character Name - Centered }}
    <div class='character-name-section' style='text-align: center; margin-bottom: 8px;'>
      <input
        name='name'
        type='text'
        value='{{actor.name}}'
        placeholder='Character Name'
        class='character-name-input'
        style='border: none; background: transparent; text-align: center; font-size: 18px; font-weight: bold; outline: none; width: 100%;'
      />
    </div>

    {{! Character Info Row - Level, Ancestry, Class as display divs }}
    <div class='character-info-row' style='text-align: center; margin-bottom: 10px; font-size: 14px; color: var(--vagabond-c-tan);'>
      Level {{system.attributes.level.value}} -- 
      {{#if system.ancestryData}}
        {{system.ancestryData.name}} 
      {{else}}
        Unknown Ancestry
      {{/if}}
      <span style='color: var(--vagabond-c-faint);'>Fighter</span> 
      {{#if system.ancestryData}}
        ({{system.ancestryData.beingType}}, {{system.ancestryData.size}} size)
      {{else}}
        (Unknown, Medium size)
      {{/if}}
    </div>

    {{! XP Row }}
    <div class='grid grid-1col' style='margin-bottom: 10px;'>
      {{! Current Luck }}
      <div class='resource'>
        <label class='resource-label'>Current Luck</label>
        <span>{{system.currentLuck}}</span>
      </div>
      <div class='resource'>
        <label class='resource-label'>{{localize 'VAGABOND.Actor.Character.FIELDS.attributes.xp.label'}}</label>
        <input
          type='text'
          name='system.attributes.xp'
          value='{{system.attributes.xp}}'
          data-dtype='Number'
        />
      </div>
    </div>

    {{! Third row: Combat Stats }}
    <div class='grid grid-5col'>
      {{! Hit Points }}
      <div class='resource'>
        <label class='resource-label'>Hit Points</label>
        <div class='resource-content flexrow flex-center flex-between'>
          <input
            type='text'
            name='system.health.value'
            value='{{system.health.value}}'
            data-dtype='Number'
            style='width: 40px;'
          />
          <span> / </span>
          <span>{{system.health.max}}</span>
        </div>
      </div>

      {{! Armor }}
      <div class='resource'>
        <label class='resource-label'>Armor</label>
        <span>{{system.armor}}</span>
      </div>

      {{! Fatigue }}
      <div class='resource'>
        <label class='resource-label'>Fatigue</label>
        <input
          type='text'
          name='system.fatigue'
          value='{{system.fatigue}}'
          data-dtype='Number'
          style='width: 40px;'
        />
      </div>

      {{! Speed - show all three values }}
      <div class='resource'>
        <label class='resource-label'>Speed</label>
        <div style='font-size: 10px;'>
          <div>{{system.speed.base}}'</div>
          <div>Crawl: {{system.speed.crawl}}'</div>
          <div>Travel: {{system.speed.travel}}mi</div>
        </div>
      </div>
    </div>
  </div>
</header>
