{{! Progress Clock Configuration Dialog Template }}
<div class="progress-clock-config-wrapper">
<form class="vagabond progress-clock-config-form">

  {{! Tab navigation }}
  <nav class="pc-tabs">
    <button type="button" class="pc-tab-btn active" data-tab="general">
      <i class="fas fa-sliders"></i> {{localize "VAGABOND.ProgressClock.TabGeneral"}}
    </button>
    <button type="button" class="pc-tab-btn" data-tab="permissions">
      <i class="fas fa-user-shield"></i> {{localize "VAGABOND.ProgressClock.TabPermissions"}}
    </button>
  </nav>

  {{! ===================== GENERAL TAB ===================== }}
  <section class="pc-tab active" data-tab="general">

    {{! Name + Clock ID (handle) — two columns }}
    <div class="form-group form-row">
      <div class="form-field">
        <label class="resource-label">{{localize "VAGABOND.ProgressClock.Name"}}</label>
        <input type="text" name="name" value="{{clock.name}}" placeholder="{{localize 'VAGABOND.UI.Labels.ClockName'}}" required />
      </div>
      <div class="form-field">
        <label class="resource-label">
          {{localize "VAGABOND.ProgressClock.Handle"}}
          <span class="pc-help" data-tooltip="{{localize 'VAGABOND.ProgressClock.HandleHint'}}">?</span>
        </label>
        <input type="text" name="handle" value="{{clock.handle}}" placeholder="{{localize 'VAGABOND.ProgressClock.Handle'}}" />
      </div>
    </div>

    {{! Type + Segments merged — clock-pie cards (4/6/8/10/12) + a Tracker card }}
    <div class="form-group">
      <label class="resource-label">{{localize "VAGABOND.ProgressClock.Type"}}</label>
      <input type="hidden" name="kind" value="{{clock.kind}}" />
      <input type="hidden" name="segments" value="{{clock.segments}}" />
      <div class="pc-card-row pc-type-row">
        {{#each clockCards}}
        <button type="button" class="pc-card pc-clock-card {{#if this.selected}}is-selected{{/if}}"
                data-kind="clock" data-segments="{{this.segments}}">
          <span class="pc-card-icon">
            <img class="pc-card-img" src="{{this.img}}" alt="" />
            <span class="pc-card-num">{{this.segments}}</span>
          </span>
          <span class="pc-card-label">{{this.segments}} seg.</span>
        </button>
        {{/each}}
        <button type="button" class="pc-card pc-tracker-card {{#if isTracker}}is-selected{{/if}}"
                data-kind="tracker">
          <span class="pc-card-icon">
            <img class="pc-card-img" src="{{trackerImg}}" alt="" />
            <input type="number" name="filled" class="pc-tracker-input" value="{{clock.filled}}" step="1" />
          </span>
          <span class="pc-card-label">{{localize "VAGABOND.ProgressClock.TypeTracker"}}</span>
        </button>
      </div>
    </div>

    {{! Size + Scene — same row (Size narrow, Scene wide) }}
    <div class="form-group form-row pc-size-scene-row">
      <div class="form-field">
        <label class="resource-label">{{localize "VAGABOND.ProgressClock.Size"}}</label>
        <input type="hidden" name="size" value="{{clock.size}}" />
        <div class="pc-size-row">
          {{#each sizeCards}}
          <button type="button" class="pc-size-btn {{#if this.selected}}is-selected{{/if}}"
                  data-size="{{this.key}}" data-tooltip="{{this.label}} ({{this.px}}px)">{{this.key}}</button>
          {{/each}}
        </div>
      </div>

      <div class="form-field">
        <label class="resource-label">{{localize "VAGABOND.ProgressClock.Scene"}}</label>
        <select name="sceneId" data-dtype="String">
          <option value="" {{#unless clock.sceneId}}selected{{/unless}}>
            {{localize "VAGABOND.ProgressClock.SceneGlobal"}}
          </option>
          {{#each sceneOptions}}
          <option value="{{this.id}}" {{#if (eq this.id ../clock.sceneId)}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>
    </div>

    {{! Linked Value — generic data binding (source → clock), full width }}
    <fieldset class="form-group pc-source-section">
      <legend>
        {{localize "VAGABOND.ProgressClock.LinkedValue"}}
        <span class="pc-help" data-tooltip="{{localize 'VAGABOND.ProgressClock.LinkedValueHint'}}">?</span>
      </legend>
      <div class="form-group">
        <label class="resource-label">{{localize "VAGABOND.ProgressClock.UpdateFrom"}}</label>
        <select name="source.mode" data-dtype="String" class="pc-source-mode">
          <option value="manual" {{#if (eq clock.source.mode "manual")}}selected{{/if}}>{{localize "VAGABOND.ProgressClock.SourceManual"}}</option>
          <option value="path" {{#if (eq clock.source.mode "path")}}selected{{/if}}>{{localize "VAGABOND.ProgressClock.SourcePath"}}</option>
          <option value="expr" {{#if (eq clock.source.mode "expr")}}selected{{/if}}>{{localize "VAGABOND.ProgressClock.SourceExpr"}}</option>
        </select>
      </div>

      {{! Path mode }}
      <div class="pc-source-path" {{#unless sourceIsPath}}style="display:none"{{/unless}}>
        <div class="form-group">
          <label class="resource-label">{{localize "VAGABOND.ProgressClock.LinkedDocument"}}</label>
          <div class="pc-source-drop" title="Drag a token, actor or item here">
            <input type="hidden" name="source.ref" value="{{clock.source.ref}}" />
            <span class="pc-source-refname">{{#if clock.source.refName}}{{clock.source.refName}}{{else}}Drag a token / actor / item here…{{/if}}</span>
            <button type="button" class="pc-source-clear" title="Clear"><i class="fas fa-times"></i></button>
          </div>
        </div>
        <div class="form-group form-row">
          <div class="form-field">
            <label class="resource-label">{{localize "VAGABOND.ProgressClock.ValuePath"}}</label>
            <input type="text" name="source.valuePath" value="{{clock.source.valuePath}}" placeholder="system.health.value" />
          </div>
          <div class="form-field">
            <label class="resource-label">{{localize "VAGABOND.ProgressClock.MaxPath"}}</label>
            <input type="text" name="source.maxPath" value="{{clock.source.maxPath}}" placeholder="system.health.max" />
          </div>
        </div>
        <label class="checkbox">
          <input type="checkbox" name="source.syncMax" {{#if clock.source.syncMax}}checked{{/if}} /> {{localize "VAGABOND.ProgressClock.SyncMax"}}
        </label>
      </div>

      {{! Formula mode }}
      <div class="pc-source-expr" {{#unless sourceIsExpr}}style="display:none"{{/unless}}>
        <div class="form-group">
          <label class="resource-label">{{localize "VAGABOND.ProgressClock.Formula"}}</label>
          <input type="text" name="source.expr" value="{{clock.source.expr}}" placeholder="@clocks.ritual.value * 2" />
        </div>
      </div>
    </fieldset>
  </section>

  {{! ===================== PERMISSIONS TAB ===================== }}
  <section class="pc-tab" data-tab="permissions">
    {{> "systems/vagabond/templates/shared/permission-matrix.hbs"}}
  </section>

  {{! Save Button — always visible }}
  <footer class="pc-footer">
    <button type="submit">
      <i class="fas fa-save"></i> {{localize "VAGABOND.ProgressClock.Save"}}
    </button>
  </footer>
</form>
</div>
