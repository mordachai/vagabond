<div class="compendium-settings-content">
  {{!-- Header Section --}}
  <header class="settings-header">
    <p class="settings-description">
      {{localize "VAGABOND.CompendiumSettings.Description"}}
    </p>
  </header>

  {{!-- Use All Toggle Section --}}
  <section class="use-all-section">
    <div class="flex-col-container">
      <div class="use-all-row">
        <label class="checkbox-label">
          <input
            type="checkbox"
            name="useAll"
            id="use-all-compendiums"
            {{checked useAllCompendiums}}
            data-action="toggleUseAll"
          />
          <strong>{{localize "VAGABOND.CompendiumSettings.UseAllAvailable"}}</strong>
        </label>
        <span class="selected-count">{{localize "VAGABOND.CompendiumSettings.SelectedCount" selected=selectedCount total=totalCompendiums}}</span>
      </div>
      <div class="use-all-hint">
        <small>{{localize "VAGABOND.CompendiumSettings.UseAllHint"}}</small>
      </div>
    </div>
  </section>

  {{!-- Quick Selection Buttons --}}
  <section class="button-section">
    <div class="button-group">
      <button type="button" data-action="selectAll" title="{{localize 'VAGABOND.CompendiumSettings.SelectAllTooltip'}}">
        <i class="fas fa-check-square"></i> {{localize "VAGABOND.CompendiumSettings.SelectAll"}}
      </button>
      <button type="button" data-action="deselectAll" title="{{localize 'VAGABOND.CompendiumSettings.DeselectAllTooltip'}}">
        <i class="far fa-square"></i> {{localize "VAGABOND.CompendiumSettings.DeselectAll"}}
      </button>
      <button type="button" data-action="selectSystem" title="{{localize 'VAGABOND.CompendiumSettings.SelectSystemTooltip'}}">
        <i class="fas fa-cube"></i> {{localize "VAGABOND.CompendiumSettings.System"}}
      </button>
      <button type="button" data-action="selectWorld" title="{{localize 'VAGABOND.CompendiumSettings.SelectWorldTooltip'}}">
        <i class="fas fa-globe"></i> {{localize "VAGABOND.CompendiumSettings.World"}}
      </button>
      <button type="button" data-action="selectModules" title="{{localize 'VAGABOND.CompendiumSettings.SelectModulesTooltip'}}">
        <i class="fas fa-puzzle-piece"></i> {{localize "VAGABOND.CompendiumSettings.Modules"}}
      </button>
    </div>
  </section>

  {{!-- Compendium Lists --}}
  {{#if grouped.system.length}}
  <section class="compendium-section">
    <h4 class="section-header">
      <i class="fas fa-cube"></i>
      <span> {{localize "VAGABOND.CompendiumSettings.SystemCompendiums"}} </span>
      <span class="count-badge">{{systemCount}}</span>
    </h4>
    <div class="compendium-grid">
      {{#each grouped.system}}
      <label class="compendium-item">
        <input
          type="checkbox"
          class="compendium-checkbox"
          name="compendiums[{{id}}]"
          data-source="system"
          {{checked selected}}
          {{#if ../useAllCompendiums}}disabled{{/if}}
        />
        <span class="compendium-info">
          <span class="compendium-title">{{title}}</span>
          <span class="compendium-meta">{{size}} {{localize "VAGABOND.CompendiumSettings.ItemsSuffix"}}</span>
        </span>
      </label>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#if grouped.world.length}}
  <section class="compendium-section">
    <h4 class="section-header">
      <i class="fas fa-globe"></i>
      <span> {{localize "VAGABOND.CompendiumSettings.WorldCompendiums"}} </span>
      <span class="count-badge">{{worldCount}}</span>
    </h4>
    <div class="compendium-grid">
      {{#each grouped.world}}
      <label class="compendium-item">
        <input
          type="checkbox"
          class="compendium-checkbox"
          name="compendiums[{{id}}]"
          data-source="world"
          {{checked selected}}
          {{#if ../useAllCompendiums}}disabled{{/if}}
        />
        <span class="compendium-info">
          <span class="compendium-title">{{title}}</span>
          <span class="compendium-meta">{{size}} {{localize "VAGABOND.CompendiumSettings.ItemsSuffix"}}</span>
        </span>
      </label>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#if grouped.module.length}}
  <section class="compendium-section">
    <h4 class="section-header">
      <i class="fas fa-puzzle-piece"></i>
      <span> {{localize "VAGABOND.CompendiumSettings.ModuleCompendiums"}} </span>
      <span class="count-badge">{{moduleCount}}</span>
    </h4>
    <div class="compendium-grid">
      {{#each grouped.module}}
      <label class="compendium-item">
        <input
          type="checkbox"
          class="compendium-checkbox"
          name="compendiums[{{id}}]"
          data-source="module"
          {{checked selected}}
          {{#if ../useAllCompendiums}}disabled{{/if}}
        />
        <span class="compendium-info">
          <span class="compendium-title">{{title}}</span>
          <span class="compendium-meta">{{size}} {{localize "VAGABOND.CompendiumSettings.ItemsSuffix"}} · {{source}}</span>
        </span>
      </label>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#unless compendiums.length}}
  <section class="no-compendiums">
    <i class="fas fa-exclamation-triangle"></i>
    <p>{{localize "VAGABOND.CompendiumSettings.NoCompendiumsFound"}}</p>
  </section>
  {{/unless}}

  {{!-- Footer --}}
  <footer class="settings-footer">
    <div class="footer-info">
      <i class="fas fa-lightbulb"></i>
      {{localize "VAGABOND.CompendiumSettings.ChangesImmediateHint"}}
    </div>
    <div class="footer-buttons">
      <button type="button" data-action="reset" class="reset-button">
        <i class="fas fa-undo"></i> {{localize "VAGABOND.CompendiumSettings.ResetToDefault"}}
      </button>
      <button type="submit" class="save-button">
        <i class="fas fa-save"></i> {{localize "VAGABOND.CompendiumSettings.SaveSettings"}}
      </button>
    </div>
  </footer>
</div>
