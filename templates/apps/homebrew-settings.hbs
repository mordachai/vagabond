<div class="homebrew-layout">

  {{!-- Left sidebar: tab buttons --}}
  <nav class="homebrew-tabs" role="tablist">
    {{#each tabs}}
    <button
      type="button"
      class="homebrew-tab-button {{#if active}}active{{/if}}{{#if hasErrors}} has-errors{{/if}}"
      data-action="switchTab"
      data-tab="{{id}}"
      role="tab"
      aria-selected="{{active}}"
      title="{{label}}"
    >
      <i class="{{icon}}"></i>
      <span class="tab-label">{{label}}</span>
      {{#if requiresReload}}
      <i class="fa-solid fa-rotate reload-badge" title="{{localize 'VAGABOND.HomebrewSettings.RequiresWorldReloadTooltip'}}"></i>
      {{/if}}
      {{#if hasErrors}}
      <i class="fa-solid fa-triangle-exclamation hb-error-badge" title="{{localize 'VAGABOND.HomebrewSettings.HasBrokenSettingsTooltip'}}"></i>
      {{/if}}
    </button>
    {{/each}}
    {{#if activeTabRequiresReload}}
    <span class="reload-notice">
      <i class="fa-solid fa-rotate"></i>
      {{localize "VAGABOND.HomebrewSettings.RequiresReload"}}
    </span>
    {{/if}}
    <button
      type="button"
      class="hb-reset-all-btn"
      data-action="resetAll"
      title="{{localize 'VAGABOND.HomebrewSettings.ResetAllTooltip'}}"
    >
      <i class="fa-solid fa-arrow-rotate-left"></i>
      {{localize "VAGABOND.HomebrewSettings.ResetAllToDefaults"}}
    </button>
  </nav>

  {{!-- Right: content + footer --}}
  <div class="homebrew-main">

    <div class="homebrew-tab-content">

      {{!-- Tab 1: Stats --}}
      {{#if showStats}}
      <div class="tab-stats">

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.StatsLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-circle-info fa-xs"></i>
            {{localize "VAGABOND.HomebrewSettings.Fields.StatsHint"}}
          </p>
          <p class="hb-hint hb-hint--warning" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-triangle-exclamation fa-xs"></i>
            {{{localize "VAGABOND.HomebrewSettings.Fields.StatsKeyWarning"}}}
          </p>
          <table class="hb-stat-table">
            <thead>
              <tr>
                <th>{{localize "VAGABOND.UI.Labels.Key"}}</th>
                <th>{{localize "VAGABOND.UI.Labels.Label"}}</th>
                <th>{{localize "VAGABOND.HomebrewSettings.Fields.Abbreviation"}}</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each statsRows}}
              <tr class="{{#if hasError}}hb-row-error{{/if}}">
                <td>
                  <input
                    type="text"
                    class="hb-stat-key-input{{#if hasError}} hb-input-error{{/if}}"
                    data-stat-index="{{@index}}"
                    data-stat-field="key"
                    value="{{key}}"
                    placeholder="{{localize 'VAGABOND.HomebrewSettings.Fields.StatKeyPlaceholder'}}"
                    title="{{#if hasError}}{{localize 'VAGABOND.HomebrewSettings.Fields.DuplicateKeyTooltip'}}{{/if}}"
                  >
                </td>
                <td>
                  <input
                    type="text"
                    class="hb-stat-label-input"
                    data-stat-index="{{@index}}"
                    data-stat-field="label"
                    value="{{label}}"
                    placeholder="{{localize 'VAGABOND.HomebrewSettings.Fields.StatNamePlaceholder'}}"
                  >
                </td>
                <td>
                  <input
                    type="text"
                    class="hb-stat-abbr-input"
                    data-stat-index="{{@index}}"
                    data-stat-field="abbreviation"
                    value="{{abbreviation}}"
                    placeholder="{{localize 'VAGABOND.HomebrewSettings.Fields.AbbrPlaceholder'}}"
                  >
                </td>
                <td>
                  <button
                    type="button"
                    class="hb-stat-remove-btn"
                    data-action="removeStat"
                    data-index="{{@index}}"
                    title="{{localize 'VAGABOND.CharBuilder.RemoveTooltip'}}"
                  ><i class="fa-solid fa-xmark"></i></button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          <button type="button" class="hb-add-btn" data-action="addStat">
            <i class="fa-solid fa-plus"></i> {{localize "VAGABOND.HomebrewSettings.Fields.AddStat"}}
          </button>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 2: Skills & Saves --}}
      {{#if showSkills}}
      <div class="tab-skills">

        {{!-- Skills --}}
        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.SkillsLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-circle-info fa-xs"></i>
            {{localize "VAGABOND.HomebrewSettings.Fields.SkillsHint"}}
          </p>
          <p class="hb-hint hb-hint--warning" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-triangle-exclamation fa-xs"></i>
            {{{localize "VAGABOND.HomebrewSettings.Fields.SkillsKeyWarning"}}}
          </p>
          <table class="hb-skills-table">
            <thead>
              <tr>
                <th>{{localize "VAGABOND.UI.Labels.Key"}}</th>
                <th>{{localize "VAGABOND.UI.Labels.Label"}}</th>
                <th>{{localize "VAGABOND.HomebrewSettings.Fields.Stat"}}</th>
                <th>{{localize "VAGABOND.HomebrewSettings.Fields.Mult"}}</th>
                <th title="{{localize 'VAGABOND.HomebrewSettings.Fields.WeaponSkillTooltip'}}">{{localize "VAGABOND.HomebrewSettings.Fields.WeaponSkillAbbr"}}</th>
                <th title="{{localize 'VAGABOND.HomebrewSettings.Fields.ShowInSkillsListTooltip'}}">{{localize "VAGABOND.HomebrewSettings.Fields.ShowInSkillsListAbbr"}}</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each skillRows}}
              <tr class="{{#if hasError}}hb-row-error{{/if}}">
                <td><input type="text" class="hb-sk-key" data-skill-index="{{index}}" data-skill-field="key" value="{{key}}" placeholder="{{localize 'VAGABOND.UI.Labels.Key'}}"></td>
                <td><input type="text" class="hb-sk-label" data-skill-index="{{index}}" data-skill-field="label" value="{{label}}" placeholder="{{localize 'VAGABOND.UI.Labels.Label'}}"></td>
                <td>
                  <select class="hb-sk-stat{{#if hasError}} hb-input-error{{/if}}" data-skill-index="{{index}}" data-skill-field="stat">
                    {{#if hasError}}
                    <option value="{{stat}}" selected disabled>⚠ {{stat}} {{localize "VAGABOND.HomebrewSettings.Fields.MissingTag"}}</option>
                    {{/if}}
                    {{#each statOptions}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </td>
                <td><input type="number" class="hb-sk-mult" data-skill-index="{{index}}" data-skill-field="trainedMultiplier" value="{{trainedMultiplier}}" min="0" max="10" step="0.5"></td>
                <td><input type="checkbox" data-skill-index="{{index}}" data-skill-field="isWeaponSkill" {{#if isWeaponSkill}}checked{{/if}}></td>
                <td><input type="checkbox" data-skill-index="{{index}}" data-skill-field="showInSkillsList" {{#if showInSkillsList}}checked{{/if}}></td>
                <td>
                  <button type="button" class="hb-sk-remove-btn" data-action="removeSkill" data-index="{{index}}" title="{{localize 'VAGABOND.CharBuilder.RemoveTooltip'}}">
                    <i class="fa-solid fa-xmark"></i>
                  </button>
                </td>
              </tr>
              <tr class="hb-subrow">
                <td colspan="7">
                  <input type="text" class="hb-subrow-input" data-skill-index="{{index}}" data-skill-field="hint" value="{{hint}}" placeholder="{{localize 'VAGABOND.HomebrewSettings.Fields.SkillHintPlaceholder'}}">
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          <button type="button" class="hb-add-btn" data-action="addSkill">
            <i class="fa-solid fa-plus"></i> {{localize "VAGABOND.HomebrewSettings.Fields.AddSkill"}}
          </button>
        </fieldset>

        {{!-- Saves --}}
        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.Saves.savesTitle"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-circle-info fa-xs"></i>
            {{localize "VAGABOND.HomebrewSettings.Fields.SavesHint"}}
          </p>
          <table class="hb-saves-table">
            <thead>
              <tr>
                <th>{{localize "VAGABOND.UI.Labels.Key"}}</th>
                <th>{{localize "VAGABOND.UI.Labels.Label"}}</th>
                <th>{{localize "VAGABOND.HomebrewSettings.Fields.Stat1"}}</th>
                <th>{{localize "VAGABOND.HomebrewSettings.Fields.Stat2"}}</th>
                <th>{{localize "VAGABOND.HomebrewSettings.Fields.Base"}}</th>
                <th>{{localize "VAGABOND.HomebrewSettings.Fields.CheckDie"}}</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each saveRows}}
              <tr class="{{#if hasError}}hb-row-error{{/if}}">
                <td><input type="text" class="hb-sv-key" data-save-index="{{index}}" data-save-field="key" value="{{key}}" placeholder="{{localize 'VAGABOND.UI.Labels.Key'}}"></td>
                <td><input type="text" class="hb-sv-label" data-save-index="{{index}}" data-save-field="label" value="{{label}}" placeholder="{{localize 'VAGABOND.UI.Labels.Label'}}"></td>
                <td>
                  <select class="hb-sv-stat{{#if stat1Missing}} hb-input-error{{/if}}" data-save-index="{{index}}" data-save-field="stat1">
                    {{#if stat1Missing}}
                    <option value="{{stat1}}" selected disabled>⚠ {{stat1}} {{localize "VAGABOND.HomebrewSettings.Fields.MissingTag"}}</option>
                    {{/if}}
                    {{#each stat1Options}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </td>
                <td>
                  <select class="hb-sv-stat{{#if stat2Missing}} hb-input-error{{/if}}" data-save-index="{{index}}" data-save-field="stat2">
                    {{#if stat2Missing}}
                    <option value="{{stat2}}" selected disabled>⚠ {{stat2}} {{localize "VAGABOND.HomebrewSettings.Fields.MissingTag"}}</option>
                    {{/if}}
                    {{#each stat2Options}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </td>
                <td><input type="number" class="hb-sv-base" data-save-index="{{index}}" data-save-field="baseValue" value="{{baseValue}}" min="1" max="40" step="1"></td>
                <td><input type="text" class="hb-sv-die" data-save-index="{{index}}" data-save-field="checkDie" value="{{checkDie}}" placeholder="1d20"></td>
                <td>
                  <button type="button" class="hb-sv-remove-btn" data-action="removeSave" data-index="{{index}}" title="{{localize 'VAGABOND.CharBuilder.RemoveTooltip'}}">
                    <i class="fa-solid fa-xmark"></i>
                  </button>
                </td>
              </tr>
              <tr class="hb-subrow">
                <td colspan="7">
                  <input type="text" class="hb-subrow-input" data-save-index="{{index}}" data-save-field="description" value="{{description}}" placeholder="{{localize 'VAGABOND.HomebrewSettings.Fields.SaveDescPlaceholder'}}">
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          <button type="button" class="hb-add-btn" data-action="addSave">
            <i class="fa-solid fa-plus"></i> {{localize "VAGABOND.HomebrewSettings.Fields.AddSave"}}
          </button>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 3: Dice --}}
      {{#if showDice}}
      <div class="tab-dice">

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.CheckDiceLegend"}}</legend>
          <div class="hb-form-group">
            <label for="hb-baseCheck">{{localize "VAGABOND.HomebrewSettings.Fields.BaseCheck"}}</label>
            <input id="hb-baseCheck" type="text" data-field="dice.baseCheck" value="{{config.dice.baseCheck}}" placeholder="1d20">
            <p class="hb-hint"><i class="fa-solid fa-circle-info fa-xs"></i> {{localize "VAGABOND.HomebrewSettings.Fields.BaseCheckHint"}}</p>
          </div>
          <div class="hb-form-group">
            <label for="hb-favorBonus">{{localize "VAGABOND.HomebrewSettings.Fields.FavorBonus"}}</label>
            <input id="hb-favorBonus" type="text" data-field="dice.favorBonus" value="{{config.dice.favorBonus}}" placeholder="1d6[favored]">
            <p class="hb-hint"><i class="fa-solid fa-circle-info fa-xs"></i> {{localize "VAGABOND.HomebrewSettings.Fields.FavorBonusHint"}}</p>
          </div>
          <div class="hb-form-group">
            <label for="hb-hinderPenalty">{{localize "VAGABOND.HomebrewSettings.Fields.HinderPenalty"}}</label>
            <input id="hb-hinderPenalty" type="text" data-field="dice.hinderPenalty" value="{{config.dice.hinderPenalty}}" placeholder="1d6[hindered]">
            <p class="hb-hint"><i class="fa-solid fa-circle-info fa-xs"></i> {{localize "VAGABOND.HomebrewSettings.Fields.HinderPenaltyHint"}}</p>
          </div>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.SkillDifficultyLegend"}}</legend>
          <div class="hb-form-group">
            <label for="hb-skillDiffBase">{{localize "VAGABOND.HomebrewSettings.Fields.DifficultyBase"}}</label>
            <input id="hb-skillDiffBase" type="number" data-field="dice.skillDifficultyBase" value="{{config.dice.skillDifficultyBase}}" min="1" max="99" step="1">
            <p class="hb-hint"><i class="fa-solid fa-circle-info fa-xs"></i> {{{localize "VAGABOND.HomebrewSettings.Fields.DifficultyBaseHint"}}}</p>
          </div>
          <div class="hb-form-group">
            <label for="hb-skillFormula">{{localize "VAGABOND.HomebrewSettings.Fields.DifficultyFormula"}}</label>
            <input id="hb-skillFormula" type="text" data-field="dice.skillFormula" value="{{config.dice.skillFormula}}" placeholder="@base - @stat * @mult - @bonus">
            <p class="hb-hint"><i class="fa-solid fa-circle-info fa-xs"></i> {{{localize "VAGABOND.HomebrewSettings.Fields.DifficultyFormulaHint"}}}</p>
          </div>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.CheckProbabilityLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.5rem;"><i class="fa-solid fa-circle-info fa-xs"></i> {{localize "VAGABOND.HomebrewSettings.Fields.CheckProbabilityHint"}}</p>
          <div class="hb-dice-chart" id="hb-dice-chart"></div>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 4: Magic --}}
      {{#if showMagic}}
      <div class="tab-magic">

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.SpellDamageLegend"}}</legend>
          <div class="hb-form-group">
            <label for="hb-spellDmg">{{localize "VAGABOND.HomebrewSettings.Fields.BaseDamageDie"}}</label>
            <input id="hb-spellDmg" type="text" data-field="dice.spellBaseDamage" value="{{config.dice.spellBaseDamage}}" placeholder="d6">
            <p class="hb-hint"><i class="fa-solid fa-circle-info fa-xs"></i> {{localize "VAGABOND.HomebrewSettings.Fields.BaseDamageDieHint"}}</p>
          </div>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.DeliveryTypesLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-circle-info fa-xs"></i>
            {{{localize "VAGABOND.HomebrewSettings.Fields.DeliveryTypesHint"}}}
          </p>
          <table class="hb-magic-dt-table">
            <thead>
              <tr>
                <th>{{localize "VAGABOND.UI.Labels.Key"}}</th>
                <th>{{localize "VAGABOND.UI.Labels.Label"}}</th>
                <th style="text-align:center" title="{{localize 'VAGABOND.HomebrewSettings.Fields.BaseCostTooltip'}}">{{localize "VAGABOND.Item.Weapon.FIELDS.baseCost.label"}}</th>
                <th style="text-align:center" title="{{localize 'VAGABOND.HomebrewSettings.Fields.RangeTooltip'}}">{{localize "VAGABOND.UI.Labels.Range"}}</th>
                <th style="text-align:center" title="{{localize 'VAGABOND.HomebrewSettings.Fields.IncrementTooltip'}}">{{localize "VAGABOND.HomebrewSettings.Fields.IncrementLabel"}}</th>
                <th style="text-align:center" title="{{localize 'VAGABOND.HomebrewSettings.Fields.IncreaseCostTooltip'}}">{{localize "VAGABOND.HomebrewSettings.Fields.IncreaseCostAbbr"}}</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each deliveryTypeRows}}
              <tr>
                <td><input type="text" class="hb-mdt-key" data-mdt-index="{{index}}" data-mdt-field="key" value="{{key}}" placeholder="{{localize 'VAGABOND.UI.Labels.Key'}}"></td>
                <td><input type="text" class="hb-mdt-label" data-mdt-index="{{index}}" data-mdt-field="label" value="{{label}}" placeholder="{{localize 'VAGABOND.UI.Labels.Label'}}"></td>
                <td><input type="number" class="hb-mdt-num" data-mdt-index="{{index}}" data-mdt-field="baseCost" value="{{baseCost}}" min="0" max="20" step="1"></td>
                <td><input type="number" class="hb-mdt-num" data-mdt-index="{{index}}" data-mdt-field="baseRange" value="{{baseRange}}" min="0" max="9999" step="1"></td>
                <td><input type="number" class="hb-mdt-num" data-mdt-index="{{index}}" data-mdt-field="increment" value="{{increment}}" min="0" max="999" step="1"></td>
                <td><input type="number" class="hb-mdt-num" data-mdt-index="{{index}}" data-mdt-field="increaseCost" value="{{increaseCost}}" min="0" max="20" step="1"></td>
                <td>
                  <button type="button" class="hb-mdt-remove-btn" data-action="removeDeliveryType" data-index="{{index}}" title="{{localize 'VAGABOND.CharBuilder.RemoveTooltip'}}">
                    <i class="fa-solid fa-xmark"></i>
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          <button type="button" class="hb-add-btn" data-action="addDeliveryType">
            <i class="fa-solid fa-plus"></i> {{localize "VAGABOND.HomebrewSettings.Fields.AddDeliveryType"}}
          </button>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 5: Leveling --}}
      {{#if showLeveling}}
      <div class="tab-leveling">

        {{!-- Max Level --}}
        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.GeneralLegend"}}</legend>
          <div class="hb-form-group">
            <label for="hb-maxLevel">{{localize "VAGABOND.HomebrewSettings.Fields.MaxLevel"}}</label>
            <input
              id="hb-maxLevel"
              type="number"
              data-field="leveling.maxLevel"
              value="{{config.leveling.maxLevel}}"
              min="1"
              max="30"
              step="1"
            >
            <p class="hb-hint"><i class="fa-solid fa-rotate fa-xs"></i> {{localize "VAGABOND.HomebrewSettings.Fields.RequiresReloadHint"}}</p>
          </div>
        </fieldset>

        {{!-- XP Per Level Table --}}
        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.XpTableLegend"}}</legend>
          <p class="hb-hint">{{localize "VAGABOND.HomebrewSettings.Fields.XpTableHint"}}</p>
          <table class="hb-xp-table">
            <thead>
              <tr><th>{{localize "VAGABOND.HomebrewSettings.Fields.ReachLevel"}}</th><th>{{localize "VAGABOND.HomebrewSettings.Fields.XpRequired"}}</th></tr>
            </thead>
            <tbody>
              {{#each config.leveling.xpTable}}
              <tr>
                <td class="level-label">{{localize "VAGABOND.HomebrewSettings.Fields.LevelLabel" level=level}}</td>
                <td>
                  <input
                    type="number"
                    data-xp-level="{{level}}"
                    value="{{xp}}"
                    min="0"
                    step="1"
                  >
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </fieldset>

        {{!-- XP Questionnaire --}}
        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.XpQuestionnaireLegend"}}</legend>
          <p class="hb-hint">{{localize "VAGABOND.HomebrewSettings.Fields.XpQuestionnaireHint"}}</p>
          <div class="hb-questions-list">
            {{#each config.leveling.xpQuestions}}
            <div class="hb-question-row">
              <i class="fa-solid fa-grip-lines q-grip"></i>
              <input
                type="text"
                class="q-text"
                data-q-index="{{@index}}"
                data-q-field="question"
                value="{{question}}"
                placeholder="{{localize 'VAGABOND.HomebrewSettings.Fields.QuestionPlaceholder'}}"
              >
              <label class="q-xp-label">{{localize "VAGABOND.HomebrewSettings.Fields.XpAbbr"}}</label>
              <input
                type="number"
                class="q-xp"
                data-q-index="{{@index}}"
                data-q-field="xp"
                value="{{xp}}"
                min="1"
                max="10"
                step="1"
              >
              <button
                type="button"
                class="q-remove-btn"
                data-action="removeXpQuestion"
                data-index="{{@index}}"
                title="{{localize 'VAGABOND.HomebrewSettings.Fields.RemoveQuestionTooltip'}}"
              ><i class="fa-solid fa-xmark"></i></button>
            </div>
            {{/each}}
          </div>
          <button type="button" class="hb-add-btn" data-action="addXpQuestion">
            <i class="fa-solid fa-plus"></i> {{localize "VAGABOND.HomebrewSettings.Fields.AddQuestion"}}
          </button>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 6: Derivations --}}
      {{#if showDerivations}}
      <div class="tab-derivations">

        <p class="hb-hint" style="margin-bottom: 0.75rem;">
          <i class="fa-solid fa-circle-info fa-xs"></i>
          {{{localize "VAGABOND.HomebrewSettings.Fields.DerivationsHint"}}}
        </p>

        <fieldset class="hb-fieldset">
          <legend>{{{localize "VAGABOND.HomebrewSettings.Fields.HealthInventoryLegend"}}}</legend>
          <div class="hb-form-group">
            <label for="hb-deriv-hp" class="{{#if derivErrors.hp}}hb-label-error{{/if}}">{{localize "VAGABOND.HomebrewSettings.Fields.MaxHealth"}}</label>
            <input
              id="hb-deriv-hp"
              type="text"
              class="hb-deriv-input{{#if derivErrors.hp}} hb-input-error{{/if}}"
              data-field="derivations.hp"
              value="{{config.derivations.hp}}"
              placeholder="@might.total"
            >
            <p class="hb-hint">{{{localize "VAGABOND.HomebrewSettings.Fields.MaxHealthHint"}}}</p>
          </div>
          <div class="hb-form-group">
            <label for="hb-deriv-inv" class="{{#if derivErrors.inventory}}hb-label-error{{/if}}">{{localize "VAGABOND.UI.Sections.Inventory"}}</label>
            <input
              id="hb-deriv-inv"
              type="text"
              class="hb-deriv-input{{#if derivErrors.inventory}} hb-input-error{{/if}}"
              data-field="derivations.inventory"
              value="{{config.derivations.inventory}}"
              placeholder="8 + @might.total"
            >
            <p class="hb-hint">{{{localize "VAGABOND.HomebrewSettings.Fields.InventorySlotsHint"}}}</p>
          </div>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.SpeedLegend"}}</legend>
          <div class="hb-form-group">
            <label for="hb-deriv-speed" class="{{#if derivErrors.speed}}hb-label-error{{/if}}">{{localize "VAGABOND.UI.Sections.Speed"}}</label>
            <input
              id="hb-deriv-speed"
              type="text"
              class="hb-deriv-input{{#if derivErrors.speed}} hb-input-error{{/if}}"
              data-field="derivations.speed"
              value="{{config.derivations.speed}}"
              placeholder="25 + floor(max(0, @dexterity.total - 2) / 2) * 5"
            >
            <p class="hb-hint">{{localize "VAGABOND.HomebrewSettings.Fields.SpeedHint"}}</p>
          </div>
          <div class="hb-form-group">
            <label for="hb-deriv-crawl" class="{{#if derivErrors.crawl}}hb-label-error{{/if}}">{{localize "VAGABOND.HomebrewSettings.Fields.CrawlSpeed"}}</label>
            <input
              id="hb-deriv-crawl"
              type="text"
              class="hb-deriv-input{{#if derivErrors.crawl}} hb-input-error{{/if}}"
              data-field="derivations.crawl"
              value="{{config.derivations.crawl}}"
              placeholder="@speed.base * 3"
            >
            <p class="hb-hint">{{{localize "VAGABOND.HomebrewSettings.Fields.CrawlSpeedHint"}}}</p>
          </div>
          <div class="hb-form-group">
            <label for="hb-deriv-travel" class="{{#if derivErrors.travel}}hb-label-error{{/if}}">{{localize "VAGABOND.HomebrewSettings.Fields.TravelSpeed"}}</label>
            <input
              id="hb-deriv-travel"
              type="text"
              class="hb-deriv-input{{#if derivErrors.travel}} hb-input-error{{/if}}"
              data-field="derivations.travel"
              value="{{config.derivations.travel}}"
              placeholder="floor(@speed.base / 5)"
            >
            <p class="hb-hint">{{{localize "VAGABOND.HomebrewSettings.Fields.TravelSpeedHint"}}}</p>
          </div>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.FatigueLegend"}}</legend>
          <div class="hb-form-group">
            <label for="hb-deriv-fatigue-pc">{{localize "VAGABOND.HomebrewSettings.Fields.PCMaxFatigue"}}</label>
            <input
              id="hb-deriv-fatigue-pc"
              type="number"
              class="hb-deriv-number"
              data-field="derivations.fatiguePCMax"
              value="{{config.derivations.fatiguePCMax}}"
              min="1"
              max="20"
              step="1"
            >
            <p class="hb-hint">{{localize "VAGABOND.HomebrewSettings.Fields.PCMaxFatigueHint"}}</p>
          </div>
          <div class="hb-form-group">
            <label for="hb-deriv-fatigue-npc">{{localize "VAGABOND.HomebrewSettings.Fields.NPCMaxFatigue"}}</label>
            <input
              id="hb-deriv-fatigue-npc"
              type="number"
              class="hb-deriv-number"
              data-field="derivations.fatigueNPCMax"
              value="{{config.derivations.fatigueNPCMax}}"
              min="1"
              max="20"
              step="1"
            >
            <p class="hb-hint">{{localize "VAGABOND.HomebrewSettings.Fields.NPCMaxFatigueHint"}}</p>
          </div>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.StatsDisplayLegend"}}</legend>
          <div class="hb-form-group">
            <label>{{localize "VAGABOND.HomebrewSettings.Fields.Layout"}}</label>
            <label class="hb-radio-option">
              <input type="radio" name="statsLayout" value="progression"
                data-field="derivations.statsLayout"
                {{#if (eq config.derivations.statsLayout "progression")}}checked{{/if}}>
              <span>{{localize "VAGABOND.HomebrewSettings.Fields.Progression"}}</span>
              <small class="hb-radio-hint">{{localize "VAGABOND.HomebrewSettings.Fields.ProgressionHint"}}</small>
            </label>
            <label class="hb-radio-option">
              <input type="radio" name="statsLayout" value="centered"
                data-field="derivations.statsLayout"
                {{#if (eq config.derivations.statsLayout "centered")}}checked{{/if}}>
              <span>{{localize "VAGABOND.HomebrewSettings.Fields.Centered"}}</span>
              <small class="hb-radio-hint">{{localize "VAGABOND.HomebrewSettings.Fields.CenteredHint"}}</small>
            </label>
          </div>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.LuckPoolLegend"}}</legend>
          <div class="hb-form-group">
            <label for="hb-deriv-luck" class="{{#if derivErrors.luckStat}}hb-label-error{{/if}}">{{localize "VAGABOND.HomebrewSettings.Fields.LuckPoolStat"}}</label>
            <select id="hb-deriv-luck" class="hb-deriv-select{{#if derivErrors.luckStat}} hb-input-error{{/if}}" data-field="derivations.luckStat">
              {{#each luckStatOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <p class="hb-hint">{{{localize "VAGABOND.HomebrewSettings.Fields.LuckPoolStatHint"}}}</p>
          </div>
          <div class="hb-form-group" style="margin-top: 0.5rem;">
            <label for="hb-term-luckTerm">{{localize "VAGABOND.HomebrewSettings.Fields.FirstWord"}}</label>
            <input id="hb-term-luckTerm" type="text" data-term-key="luckTerm" value="{{config.terms.luckTerm}}" placeholder="Luck">
            <p class="hb-hint">{{localize "VAGABOND.HomebrewSettings.Fields.FirstWordHint"}}</p>
          </div>
          <div class="hb-form-group">
            <label for="hb-term-poolTerm">{{localize "VAGABOND.HomebrewSettings.Fields.SecondWord"}}</label>
            <input id="hb-term-poolTerm" type="text" data-term-key="poolTerm" value="{{config.terms.poolTerm}}" placeholder="Pool">
            <p class="hb-hint">{{{localize "VAGABOND.HomebrewSettings.Fields.SecondWordHint" luck=config.terms.luckTerm pool=config.terms.poolTerm}}}</p>
          </div>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 7: Damage Types --}}
      {{#if showDamageTypes}}
      <div class="tab-damage-types">

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.DamageTypesLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-circle-info fa-xs"></i>
            {{{localize "VAGABOND.HomebrewSettings.Fields.DamageTypesHint"}}}
          </p>
          <table class="hb-dt-table">
            <thead>
              <tr>
                <th class="hb-dt-th-icon"></th>
                <th>{{localize "VAGABOND.UI.Labels.Key"}}</th>
                <th>{{localize "VAGABOND.UI.Labels.Label"}}</th>
                <th>{{localize "VAGABOND.HomebrewSettings.Fields.FaIconClass"}}</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each config.damageTypes}}
              <tr>
                <td class="hb-dt-icon-cell">
                  <i class="{{icon}}" data-dt-icon-preview="{{@index}}"></i>
                </td>
                <td>
                  <input
                    type="text"
                    class="hb-dt-key-input"
                    data-dt-index="{{@index}}"
                    data-dt-field="key"
                    value="{{key}}"
                    placeholder="{{localize 'VAGABOND.UI.Labels.Key'}}"
                  >
                </td>
                <td>
                  <input
                    type="text"
                    class="hb-dt-label-input"
                    data-dt-index="{{@index}}"
                    data-dt-field="label"
                    value="{{label}}"
                    placeholder="{{localize 'VAGABOND.UI.Labels.Label'}}"
                  >
                </td>
                <td>
                  <input
                    type="text"
                    class="hb-dt-icon-input"
                    data-dt-index="{{@index}}"
                    data-dt-field="icon"
                    value="{{icon}}"
                    placeholder="{{localize 'VAGABOND.HomebrewSettings.Fields.IconPlaceholder'}}"
                  >
                </td>
                <td>
                  <button
                    type="button"
                    class="hb-dt-remove-btn"
                    data-action="removeDamageType"
                    data-index="{{@index}}"
                    title="{{localize 'VAGABOND.CharBuilder.RemoveTooltip'}}"
                  ><i class="fa-solid fa-xmark"></i></button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          <button type="button" class="hb-add-btn" data-action="addDamageType">
            <i class="fa-solid fa-plus"></i> {{localize "VAGABOND.HomebrewSettings.Fields.AddDamageType"}}
          </button>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 8: Stat Cap --}}
      {{#if showStatCap}}
      <div class="tab-stat-cap">

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.StatCapLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-circle-info fa-xs"></i>
            {{{localize "VAGABOND.HomebrewSettings.Fields.StatCapHint"}}}
          </p>
          <div class="hb-form-group">
            <label for="hb-statCap">{{localize "VAGABOND.HomebrewSettings.Fields.StatCapLegend"}}</label>
            <input
              id="hb-statCap"
              type="number"
              data-field="statCap"
              value="{{config.statCap}}"
              min="1"
              max="20"
              step="1"
            >
            <p class="hb-hint"><i class="fa-solid fa-rotate fa-xs"></i> {{localize "VAGABOND.HomebrewSettings.Fields.RequiresReloadHint"}}</p>
          </div>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.StatArraysLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-circle-info fa-xs"></i>
            {{localize "VAGABOND.HomebrewSettings.Fields.StatArraysHint"}}
          </p>
          <table class="hb-sa-table">
            <thead>
              <tr>
                <th class="hb-sa-roll-col">{{localize "VAGABOND.HomebrewSettings.Fields.RollAbbr"}}</th>
                {{#each config.stats}}
                <th title="{{label}}">{{abbreviation}}</th>
                {{/each}}
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each statArrayRows}}
              <tr>
                <td class="hb-sa-roll-col">{{roll}}</td>
                {{#each values}}
                <td><input type="number" class="hb-sa-value" data-array-index="{{@../index}}" data-value-index="{{@index}}" value="{{this}}" min="1" max="20" step="1"></td>
                {{/each}}
                <td>
                  <button type="button" class="hb-sa-remove-btn" data-action="removeStatArray" data-index="{{index}}" title="{{localize 'VAGABOND.HomebrewSettings.Fields.RemoveArrayTooltip'}}">
                    <i class="fa-solid fa-xmark"></i>
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          <button type="button" class="hb-add-btn" data-action="addStatArray" style="margin-top: 0.4rem;">
            <i class="fa-solid fa-plus"></i> {{localize "VAGABOND.HomebrewSettings.Fields.AddArray"}}
          </button>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 9: Advanced --}}
      {{#if showAdvanced}}
      <div class="tab-advanced">

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.SkillMultipliersLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-circle-info fa-xs"></i>
            {{{localize "VAGABOND.HomebrewSettings.Fields.SkillMultipliersHint"}}}
          </p>
          <div class="hb-form-group">
            <label for="hb-mult-trained">{{localize "VAGABOND.HomebrewSettings.Fields.Trained"}}</label>
            <input
              id="hb-mult-trained"
              type="number"
              data-field="multipliers.trained"
              value="{{config.multipliers.trained}}"
              min="0"
              max="10"
              step="0.5"
            >
            <p class="hb-hint">{{localize "VAGABOND.HomebrewSettings.Fields.TrainedHint"}}</p>
          </div>
          <div class="hb-form-group">
            <label for="hb-mult-untrained">{{localize "VAGABOND.HomebrewSettings.Fields.Untrained"}}</label>
            <input
              id="hb-mult-untrained"
              type="number"
              data-field="multipliers.untrained"
              value="{{config.multipliers.untrained}}"
              min="0"
              max="10"
              step="0.5"
            >
            <p class="hb-hint">{{localize "VAGABOND.HomebrewSettings.Fields.UntrainedHint"}}</p>
          </div>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 10: Terms --}}
      {{#if showTerms}}
      <div class="tab-terms">

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.GeneralLegend"}}</legend>
          <table class="hb-terms-table">
            <thead>
              <tr><th>{{localize "VAGABOND.HomebrewSettings.Fields.Field"}}</th><th>{{localize "VAGABOND.UI.Labels.Label"}}</th><th class="hb-terms-default-col">{{localize "VAGABOND.HomebrewSettings.Fields.Default"}}</th></tr>
            </thead>
            <tbody>
              <tr>
                <td>{{{localize "VAGABOND.HomebrewSettings.Fields.InventoryTermRow"}}}</td>
                <td><input type="text" data-term-key="inventory" value="{{config.terms.inventory}}" placeholder="Inventory" /></td>
                <td class="hb-hint">Inventory</td>
              </tr>
            </tbody>
          </table>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.Actor.Tabs.Magic"}}</legend>
          <table class="hb-terms-table">
            <thead>
              <tr><th>{{localize "VAGABOND.HomebrewSettings.Fields.Field"}}</th><th>{{localize "VAGABOND.UI.Labels.Label"}}</th><th class="hb-terms-default-col">{{localize "VAGABOND.HomebrewSettings.Fields.Default"}}</th></tr>
            </thead>
            <tbody>
              <tr>
                <td>{{localize "VAGABOND.HomebrewSettings.Fields.MagicTermRow"}}</td>
                <td><input type="text" data-term-key="magic" value="{{config.terms.magic}}" placeholder="Magic" /></td>
                <td class="hb-hint">Magic</td>
              </tr>
              <tr>
                <td>{{{localize "VAGABOND.HomebrewSettings.Fields.SpellsTermRow"}}}</td>
                <td><input type="text" data-term-key="spells" value="{{config.terms.spells}}" placeholder="Spells" /></td>
                <td class="hb-hint">Spells</td>
              </tr>
              <tr>
                <td>{{localize "VAGABOND.HomebrewSettings.Fields.ManaTermRow"}}</td>
                <td><input type="text" data-term-key="mana" value="{{config.terms.mana}}" placeholder="Mana" /></td>
                <td class="hb-hint">Mana</td>
              </tr>
              <tr>
                <td>{{localize "VAGABOND.HomebrewSettings.Fields.MaxManaTermRow"}}</td>
                <td><input type="text" data-term-key="maxMana" value="{{config.terms.maxMana}}" placeholder="Max Mana" /></td>
                <td class="hb-hint">Max Mana</td>
              </tr>
              <tr>
                <td>{{localize "VAGABOND.HomebrewSettings.Fields.ManaPerCastTermRow"}}</td>
                <td><input type="text" data-term-key="manaPerCast" value="{{config.terms.manaPerCast}}" placeholder="Mana/Cast" /></td>
                <td class="hb-hint">Mana/Cast</td>
              </tr>
              <tr>
                <td>{{localize "VAGABOND.HomebrewSettings.Fields.CastingSkillTermRow"}}</td>
                <td><input type="text" data-term-key="castingSkill" value="{{config.terms.castingSkill}}" placeholder="Mana Skill" /></td>
                <td class="hb-hint">Mana Skill</td>
              </tr>
            </tbody>
          </table>
        </fieldset>

        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.UI.Sections.Wealth"}}</legend>
          <table class="hb-terms-table">
            <thead>
              <tr><th>{{localize "VAGABOND.HomebrewSettings.Fields.Field"}}</th><th>{{localize "VAGABOND.UI.Labels.Label"}}</th><th class="hb-terms-default-col">{{localize "VAGABOND.HomebrewSettings.Fields.Default"}}</th></tr>
            </thead>
            <tbody>
              <tr>
                <td>{{localize "VAGABOND.HomebrewSettings.Fields.WealthTermRow"}}</td>
                <td><input type="text" data-term-key="wealth" value="{{config.terms.wealth}}" placeholder="Wealth" /></td>
                <td class="hb-hint">Wealth</td>
              </tr>
              <tr>
                <td>{{localize "VAGABOND.HomebrewSettings.Fields.GoldTermRow"}}</td>
                <td><input type="text" data-term-key="gold" value="{{config.terms.gold}}" placeholder="Gold" /></td>
                <td class="hb-hint">Gold</td>
              </tr>
              <tr>
                <td>{{localize "VAGABOND.HomebrewSettings.Fields.SilverTermRow"}}</td>
                <td><input type="text" data-term-key="silver" value="{{config.terms.silver}}" placeholder="Silver" /></td>
                <td class="hb-hint">Silver</td>
              </tr>
              <tr>
                <td>{{localize "VAGABOND.HomebrewSettings.Fields.CopperTermRow"}}</td>
                <td><input type="text" data-term-key="copper" value="{{config.terms.copper}}" placeholder="Copper" /></td>
                <td class="hb-hint">Copper</td>
              </tr>
            </tbody>
          </table>
        </fieldset>

      </div>
      {{/if}}

      {{!-- Tab 11: Library --}}
      {{#if showLibrary}}
      <div class="tab-library">

        {{!-- Library list --}}
        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.LibraryLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.75rem;">
            <i class="fa-solid fa-circle-info fa-xs"></i>
            {{localize "VAGABOND.HomebrewSettings.Fields.LibraryHint"}}
          </p>
          <p class="hb-lib-path">
            <i class="fa-solid fa-folder fa-xs"></i>
            <code>{{library.filePath}}</code>
            <span class="hb-lib-path-note">{{localize "VAGABOND.HomebrewSettings.Fields.LibraryPathNote"}}</span>
          </p>

          {{#if library.hasEntries}}
          <table class="hb-library-table">
            <thead>
              <tr>
                <th></th>
                <th>{{localize "VAGABOND.UI.Labels.Name"}}</th>
                <th>{{localize "VAGABOND.HomebrewSettings.Fields.Saved"}}</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each library.entries}}
              <tr class="hb-library-row {{#if isActive}}hb-library-row--active{{/if}}">
                <td class="hb-lib-status-cell">
                  {{#if isActive}}
                  <i class="fa-solid fa-circle-check hb-active-icon" title="{{#if isModified}}{{localize 'VAGABOND.HomebrewSettings.Fields.ActiveModifiedTooltip'}}{{else}}{{localize 'VAGABOND.HomebrewSettings.Fields.ActiveTooltip'}}{{/if}}"></i>
                  {{/if}}
                </td>
                <td class="hb-lib-name-cell">
                  {{name}}
                  {{#if isModified}}<span class="hb-modified-badge">{{localize "VAGABOND.HomebrewSettings.Fields.ModifiedBadge"}}</span>{{/if}}
                </td>
                <td class="hb-lib-date-cell">{{savedAtDisplay}}</td>
                <td class="hb-lib-actions-cell">
                  {{#if isModified}}
                  <button type="button" class="hb-lib-update-btn" data-action="updateHomebrew" title="{{localize 'VAGABOND.HomebrewSettings.Fields.UpdateEntryTooltip'}}">
                    <i class="fa-solid fa-floppy-disk"></i>
                  </button>
                  {{else}}
                  <button type="button" class="hb-lib-activate-btn{{#if isActive}} hb-lib-activate-btn--active{{/if}}" data-action="activateHomebrew" data-id="{{id}}" title="{{#if isActive}}{{localize 'VAGABOND.HomebrewSettings.Fields.AlreadyActiveTooltip'}}{{else}}{{localize 'VAGABOND.HomebrewSettings.Fields.LoadApplyTooltip'}}{{/if}}" {{#if isActive}}disabled{{/if}}>
                    <i class="fa-solid fa-play"></i>
                  </button>
                  {{/if}}
                  <button type="button" class="hb-lib-export-btn" data-action="exportConfig" data-id="{{id}}" title="{{localize 'VAGABOND.HomebrewSettings.Fields.ExportTooltip'}}">
                    <i class="fa-solid fa-file-arrow-down"></i>
                  </button>
                  <button type="button" class="hb-lib-delete-btn" data-action="deleteHomebrew" data-id="{{id}}" title="{{localize 'VAGABOND.HomebrewSettings.Fields.RemoveFromLibraryTooltip'}}">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          {{else}}
          <p class="hb-hint hb-lib-empty">{{localize "VAGABOND.HomebrewSettings.Fields.NoSavedHomebrews"}}</p>
          {{/if}}

          {{#if library.showSaveForm}}
          <div class="hb-save-form">
            <input
              type="text"
              id="hb-lib-name-input"
              class="hb-lib-name-input"
              value="{{library.importedName}}"
              placeholder="{{localize 'VAGABOND.HomebrewSettings.Fields.ConfigNamePlaceholder'}}"
              autofocus
            >
            <button type="button" class="hb-lib-save-confirm-btn" data-action="saveToLibrary">
              <i class="fa-solid fa-floppy-disk"></i> {{localize "VAGABOND.HomebrewSettings.Save"}}
            </button>
            <button type="button" class="hb-lib-cancel-btn" data-action="toggleSaveForm">
              {{localize "VAGABOND.HomebrewSettings.Fields.Cancel"}}
            </button>
          </div>
          {{else}}
          <button type="button" class="hb-add-btn hb-lib-add-btn" data-action="toggleSaveForm">
            <i class="fa-solid fa-plus"></i> {{localize "VAGABOND.HomebrewSettings.Fields.SaveCurrentToLibrary"}}
          </button>
          {{/if}}
        </fieldset>

        {{!-- Import --}}
        <fieldset class="hb-fieldset">
          <legend>{{localize "VAGABOND.HomebrewSettings.Fields.ImportLegend"}}</legend>
          <p class="hb-hint" style="margin-bottom: 0.5rem;">{{{localize "VAGABOND.HomebrewSettings.Fields.ImportHint"}}}</p>
          <button type="button" class="hb-share-btn" data-action="importConfig">
            <i class="fa-solid fa-file-arrow-up"></i>
            {{localize "VAGABOND.HomebrewSettings.Fields.ImportHomebrew"}}
          </button>
        </fieldset>

      </div>
      {{/if}}

    </div>{{!-- .homebrew-tab-content --}}

    <footer class="form-footer homebrew-footer">
      {{#if hasAnyErrors}}
      <span class="hb-broken-notice" title="{{localize 'VAGABOND.HomebrewSettings.Fields.BrokenSettingsTooltip'}}">
        <i class="fa-solid fa-triangle-exclamation"></i>
        {{localize "VAGABOND.HomebrewSettings.Fields.BrokenSettingsNotice"}}
      </span>
      {{/if}}
      <button type="button" class="reset-btn" data-action="resetDefaults" data-tab="{{activeTab}}">
        <i class="fa-solid fa-undo"></i>
        {{localize "VAGABOND.HomebrewSettings.ResetTab"}}
      </button>
      <button type="submit">
        <i class="fa-solid fa-floppy-disk"></i>
        {{localize "VAGABOND.HomebrewSettings.Save"}}
      </button>
      <button type="button" data-action="saveAndClose">
        <i class="fa-solid fa-floppy-disk"></i>
        {{localize "VAGABOND.HomebrewSettings.Fields.SaveAndClose"}}
      </button>
      <button type="button" data-action="close">
        {{localize "Cancel"}}
      </button>
    </footer>

  </div>{{!-- .homebrew-main --}}

</div>{{!-- .homebrew-layout --}}
