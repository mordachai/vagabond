{{!-- Vagabond NPC HUD — frameless floating overlay. Single root element.
      The outer app element carries `.vbd-hud .vbd-hud--npc` (DEFAULT_OPTIONS
      classes) and owns the fixed positioning; this inner root only does layout.
      Reuses the shared `.vh-*` vocabulary from the PC HUD where identical. --}}
<div class="vh-root">

  {{!-- ============ DETAIL PANEL (above / below, toggled by chevrons) ============ --}}
  <div class="vh-panel {{#unless panelOpen}}vh-panel--closed{{/unless}}" data-state="{{#if panelOpen}}open{{else}}closed{{/if}}">
    {{#if detail}}
      <div class="vh-panel-header">
        <h4 class="vh-section-title">{{detail.name}}</h4>
        {{#if (eq detail.type 'ability')}}
          <button type="button" class="vh-panel-chat" data-action="clickAbilityName" data-index="{{detail.index}}" data-tooltip="{{localize 'VAGABOND.Hud.Menu.SendToChat'}}">
            <i class="fas fa-comment"></i>
          </button>
        {{/if}}
        <button type="button" class="vh-panel-close" data-action="closeDetail" data-tooltip="{{localize 'VAGABOND.Hud.Menu.ClosePanel'}}">
          <i class="fas fa-xmark"></i>
        </button>
      </div>

      {{#if (eq detail.type 'action')}}
        <div class="vh-npc-detail-line">
          {{#if detail.damageTypeIcon}}<span class="vh-npc-dt"><i class="{{detail.damageTypeIcon}}"></i>{{detail.damageTypeLabel}}</span>{{/if}}
          {{#if detail.flatDamage}}<span class="vh-npc-dmg">{{detail.flatDamage}}</span>{{/if}}
          {{#if (and detail.flatDamage detail.hasRollDamage)}}<span class="vh-npc-sep">/</span>{{/if}}
          {{#if detail.hasRollDamage}}<span class="vh-npc-dmg">({{detail.rollDamage}})</span>{{/if}}
          {{#if detail.recharge}}<span class="vh-npc-recharge"><i class="fas fa-hourglass-half"></i>{{{detail.rechargeFormatted}}}</span>{{/if}}
        </div>
        {{#if detail.note}}<div class="vh-npc-note">[{{detail.note}}]</div>{{/if}}
        {{#if detail.extraInfoFormatted}}<div class="vh-acc-body">{{{detail.extraInfoFormatted}}}</div>{{/if}}
        {{#if detail.statuses.length}}
          <div class="vh-npc-onhit">
            <span class="vh-npc-onhit-label">{{localize "VAGABOND.Status.OnHitEffects"}}:</span>
            {{#each detail.statuses}}
              <span class="vh-npc-status-chip" data-tooltip="{{label}}{{#if save}} ({{save}}){{/if}}">
                <img class="status-condition-icon" src="{{icon}}" alt="{{label}}" />{{label}}
              </span>
            {{/each}}
          </div>
        {{/if}}
      {{else}}
        <div class="vh-acc-body">{{{detail.enrichedDescription}}}</div>
      {{/if}}
    {{/if}}
  </div>

  {{!-- ============ BODY ============ --}}
  <div class="vh-body">

    {{!-- Floating cluster: armor shield (NPCs have no weapon circles) --}}
    <div class="vh-floating">
      <div class="vh-armor" data-tooltip="{{system.armorDescription}}">
        <i class="fas fa-shield"></i><span class="vh-armor-val">{{armor}}</span>
      </div>
    </div>

    {{!-- Ongoing status icons — floating vertical strip in the left gutter.
         Same .status-icon markup + menu as the sheet: left-click = chat,
         right-click = Send to Chat / Remove. --}}
    <div class="vh-hud-statuses">{{~#each statusEffects}}<div class="status-icon" data-effect-id="{{id}}" data-effect-uuid="{{uuid}}" data-tooltip="{{name}}" data-action="statusClick"><img src="{{icon}}" alt="{{name}}" /></div>{{/each~}}</div>

    {{!-- Main row: portrait | vitals | center --}}
    <div class="vh-main-grid">

      <div class="vh-drag">
        <div class="vh-npc-portrait">
          <img src="{{img}}" alt="{{name}}" />
        </div>
      </div>

      <div class="vh-vitals">
        <div class="vh-vital vh-vital--hd" data-tooltip="{{localize 'VAGABOND.Actor.NPC.FIELDS.hd.label'}}"><i class="fas fa-dice-d6"></i><span>{{hd}}</span></div>
        <div class="vh-vital vh-vital--hp rollable" data-tooltip="{{localize 'VAGABOND.Hud.HPHint'}} - Max HP:{{hp.max}}"><i class="fas fa-heart"></i><span>{{hp.value}}</span></div>
        <div class="vh-vital vh-vital--fatigue rollable" data-tooltip="{{localize 'VAGABOND.Hud.FatigueHint'}}"><i class="fas fa-skull"></i><span>{{fatigue.value}}</span></div>
        <div class="vh-vital vh-vital--morale rollable" data-action="rollMorale" data-tooltip="{{localize 'VAGABOND.Actor.NPC.MoraleCheck.tooltip'}}"><i class="fas fa-flag"></i><span>{{#if morale}}{{morale}}{{else}}–{{/if}}</span></div>
      </div>

      <div class="vh-center">
        {{!-- Name row: name + book-open toggle (mirrors the sheet header's
              description button) — opens system.description in the detail panel. --}}
        <div class="vh-name-row">
          <div class="vh-name">{{name}}</div>
          {{#if hasDescription}}
            <button type="button"
                    class="vh-name-desc {{#if (and detail (eq detail.type 'description'))}}is-open{{/if}}"
                    data-action="openDetail" data-detail-type="description" data-index="0"
                    data-tooltip="{{localize 'VAGABOND.Actor.NPC.FIELDS.description.label'}}">
              <i class="fas fa-book-open"></i>
            </button>
          {{/if}}
        </div>

        <div class="vh-controls vh-npc-speed">
          <span class="vh-ctl" data-tooltip="{{localize 'VAGABOND.UI.Sections.Speed'}}"><i class="fas fa-shoe-prints"></i>{{speed}}'</span>
          {{#each speedTypes}}
            <span class="vh-ctl" data-tooltip="{{label}}">   {{label}}{{#if value}} {{value}}'{{/if}}</span>
          {{/each}}
        </div>

        <div class="vh-npc-meta">
          {{#if size}}<span class="vh-badge">{{size}}</span>{{/if}}
          {{#if beingType}}<span class="vh-badge">{{beingType}}</span>{{/if}}
          {{#if zone}}<span class="vh-badge vh-badge--zone">{{zone}}</span>{{/if}}
          {{#if appearingEnriched}}<span class="vh-badge vh-badge--app" data-tooltip="{{localize 'VAGABOND.Actor.NPC.FIELDS.appearing.label'}}"><i class="fas fa-users"></i>{{{appearingEnriched}}}</span>{{/if}}
        </div>
      </div>
    </div>

    {{!-- Always-on info strip: senses + resistances --}}
    {{#if hasInfoStrip}}
      <div class="vh-npc-info">
        {{#if senses}}<span class="vh-info-group vh-info-senses"><i class="fas fa-eye"></i>{{senses}}</span>{{/if}}
        {{#if immunities.length}}<span class="vh-info-group">{{#each immunities}}<i class="{{icon}} vh-info-immune" data-tooltip="{{localize 'VAGABOND.Actor.NPC.FIELDS.immunities.label'}}: {{label}}"></i>{{/each}}</span>{{/if}}
        {{#if weaknesses.length}}<span class="vh-info-group">{{#each weaknesses}}<i class="{{icon}} vh-info-weak" data-tooltip="{{localize 'VAGABOND.Actor.NPC.FIELDS.weaknesses.label'}}: {{label}}"></i>{{/each}}</span>{{/if}}
        {{#if statusImmunities.length}}<span class="vh-info-group">{{#each statusImmunities}}<img class="status-condition-icon vh-info-status" src="{{icon}}" data-tooltip="{{localize 'VAGABOND.Actor.NPC.FIELDS.statusImmunities.label'}}: {{label}}" />{{/each}}</span>{{/if}}
      </div>
    {{/if}}

    {{!-- Action chips — single inline row: [recharge?] name [chevron?].
         Click name = roll routine; chevron = open detail panel.
         When recharging (rechargeCountdownId set), the chip turns red and the
         hourglass appears in front of the name — clicking it rolls the recharge
         (reuses the sheet's rollRechargeCountdown handler). --}}
    {{#if actions.length}}
      <div class="vh-npc-chips">
        {{#each actions}}
          <div class="vh-chip vh-chip--action
                      {{#unless hasDetail}}vh-chip--solo{{/unless}}
                      {{#if rechargeCountdownId}}is-recharging{{/if}}
                      {{#if (and @root.detail (and (eq @root.detail.type 'action') (eq @root.detail.index index)))}}is-open{{/if}}">
            <div class="vh-chip-main" data-action="clickActionName" data-index="{{index}}" data-tooltip="{{name}}{{#if note}} [{{note}}]{{/if}}">
              {{#if rechargeCountdownId}}
                <i class="fas fa-hourglass-half vh-chip-recharge" data-action="rollRechargeCountdown" data-countdown-id="{{rechargeCountdownId}}" data-tooltip="{{localize 'VAGABOND.Actor.NPC.Action.Recharge'}}"></i>
              {{/if}}
              <span class="vh-chip-name">{{name}}</span>
            </div>
            {{#if hasDetail}}
              <button type="button" class="vh-chip-exp" data-action="openDetail" data-detail-type="action" data-index="{{index}}" data-tooltip="{{localize 'VAGABOND.Hud.Menu.Read'}}">
                <i class="fas fa-square-list"></i>
              </button>
            {{/if}}
          </div>
        {{/each}}
      </div>
    {{/if}}

    {{!-- Ability chips (GM-only info; click name = open description panel,
         chat is posted from the panel header bubble, not the chip) --}}
    {{#if abilities.length}}
      <div class="vh-npc-chips vh-npc-chips--abilities">
        {{#each abilities}}
          <div class="vh-chip vh-chip--ability {{#if (and @root.detail (and (eq @root.detail.type 'ability') (eq @root.detail.index index)))}}is-open{{/if}}"
               data-action="openDetail" data-detail-type="ability" data-index="{{index}}" data-tooltip="{{name}}">
            <span class="vh-chip-name">{{name}}</span>
          </div>
        {{/each}}
      </div>
    {{/if}}

  </div>
</div>
