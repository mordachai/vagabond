<select
  name='{{name}}'
  {{#if cssClass}}class='{{cssClass}}'{{/if}}
  data-dtype='String'
  {{#if title}}title='{{title}}'{{/if}}
  {{#if disabled}}disabled{{/if}}
>
  {{#if showAncestryDefault}}
    <option value=''>{{#if ancestryName}}{{ancestryBeingType}} (from ancestry){{else}}Humanlike (default){{/if}}</option>
  {{/if}}
  {{#each config.beingTypes as |label key|}}
    <option value='{{key}}' {{#if (eq ../selected key)}}selected{{/if}}>{{localize label}}</option>
  {{/each}}
</select>
