{{! Container Details Tab }}
<section
  class='tab details {{tab.cssClass}}{{#if system.locked}} container-locked{{/if}}'
  data-group='primary'
  data-tab='details'
>
  <div class='equipment-item-content'>
    {{! Description Section }}
    <div class='form-group'>
      {{#unless system.locked}}
        <label class='resource-label'>{{localize 'VAGABOND.Item.base.FIELDS.description.label'}}</label>
      {{/unless}}
      <div class='equipment-description'>
        {{#if editable}}
          <prose-mirror name="system.description" data-document-uuid="{{item.uuid}}" value="{{system.description}}" collaborate="true" toggled="true">
            {{{enriched.description}}}
          </prose-mirror>
        {{else}}
          <div>{{{enriched.description}}}</div>
        {{/if}}
      </div>
    </div>

    {{! Container Configuration (only in unlocked mode) }}
    {{#unless system.locked}}
      <div class='form-group'>
        <label class='resource-label'>{{localize "VAGABOND.UI.Sections.ContainerConfig"}}</label>
        <p class='field-hint'>{{localize "VAGABOND.UI.Labels.ContainerConfigHint"}}</p>
      </div>
    {{/unless}}

    {{!-- Filter bar --}}
    <div class="container-search-header">
        <div class="search-field">
            <i class="fas fa-search"></i>
            <input type="text" class="container-search" placeholder="{{localize 'VAGABOND.UI.Labels.SearchItemsPlaceholder'}}" spellcheck="false">
        </div>
        <div class="item-counter">
            {{localize "VAGABOND.UI.Labels.Items"}}: <span id="visible-count">{{containerItems.length}}</span> / <span id="total-count">{{containerItems.length}}</span>
        </div>
    </div>
    {{! Container Items List }}
    <div class='form-group' data-drop-container='true'>
      {{#if containerItems.length}}
        <div class='container-items-list'>
          <table class='container-items-table'>
            <thead>
              <tr>
                <th>{{localize "VAGABOND.UI.Labels.Name"}}</th>
                <th>{{localize "VAGABOND.UI.Labels.Damage"}}</th>
                <th>{{localize "VAGABOND.UI.Labels.Slots"}}</th>
                <th>{{localize "VAGABOND.UI.Labels.Cost"}}</th>
                <th>{{localize "VAGABOND.UI.Labels.Actions"}}</th>
              </tr>
            </thead>
            <tbody>
              {{#each containerItems}}
                <tr class='container-item-row draggable' data-item-index='{{index}}' draggable='true'>
                  <td class='item-name'>
                    <img src='{{img}}' alt='{{name}}' class='item-icon' data-item-index='{{@index}}' />
                    <div class='item-name-container'>
                      <div class='item-name-text'>{{name}}</div>
                      <div class='item-type-text'>{{typeName}}</div>
                    </div>
                  </td>
                  <td class='item-damage'>{{damageDisplay}}</td>
                  <td class='item-slots'>{{slotsDisplay}}</td>
                  <td class='item-cost'>{{costDisplay}}</td>
                  <td class='item-actions'>
                    {{#if ../item.actor}}
                      <button
                        type='button'
                        class='equip-from-container'
                        data-action='equipFromContainer'
                        data-item-index='{{@index}}'
                        title='{{localize "VAGABOND.UI.Labels.EquipFromContainerTooltip"}}'
                      >
                        <i class='fas fa-hand-paper'></i>
                      </button>
                    {{/if}}
                    <button
                      type='button'
                      class='delete-from-container'
                      data-action='deleteFromContainer'
                      data-item-index='{{@index}}'
                      title='{{localize "VAGABOND.UI.Labels.DeleteItemTooltip"}}'
                    >
                      <i class='fas fa-trash'></i>
                    </button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <div class='container-empty-state' data-drop-container='true'>
          <p><i class='fas fa-inbox'></i> {{localize "VAGABOND.UI.Labels.EmptyContainer"}}</p>
          <p class='hint'>{{localize "VAGABOND.UI.Labels.DragItemsHint"}}</p>
        </div>
      {{/if}}
    </div>
  </div>
</section>
