{{! Class Details Tab }}
<section
  class='tab details {{tab.cssClass}}'
  data-group='primary'
  data-tab='details'
>
  {{! Description Section }}
  <div>
    <label class='resource-label'>{{localize 'VAGABOND.Item.Tabs.Description'}}</label>
    <div class='class-description'>
      {{#if editable}}
        <prose-mirror name="system.description" data-document-uuid="{{item.uuid}}" value="{{system.description}}" collaborate="true" toggled="true">
          {{{enrichedDescription}}}
        </prose-mirror>
      {{else}}
        <div>{{{enrichedDescription}}}</div>
      {{/if}}
    </div>
  </div>

  {{! Level Features Section }}
  <div class='level-features-section' style='margin-top: 20px;'>
    <h3>Level Features</h3>

    {{#each levelGroups as |group|}}
      <div class='level-group' style='margin-bottom: 15px; border: 1px solid #ccc; padding: 10px;'>
        <div class='level-header' style='display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;'>
          <h4 style='margin: 0;'>Level {{group.level}}</h4>
          {{#if @root.editable}}
            <button
              type='button'
              class='item-control'
              data-action='addLevelFeature'
              data-level='{{group.level}}'
              data-tooltip='Add Feature to Level {{group.level}}'
              style='padding: 2px 8px; font-size: 12px;'
            >
              <i class='fas fa-plus'></i> Add Feature
            </button>
          {{/if}}
        </div>

        {{#if group.features.length}}
          <ol class='features-list' style='margin: 0; padding-left: 20px;'>
            {{#each group.features as |feature|}}
              <li class='feature-item' style='margin-bottom: 10px;' data-feature-index='{{feature.index}}'>
                <div class='feature-content'>
                  {{#if @root.editable}}
                    <div style='display: flex; gap: 10px; margin-bottom: 5px; align-items: center;'>
                      <input
                        type='text'
                        name='system.levelFeatures.{{feature.index}}.name'
                        value='{{feature.name}}'
                        placeholder='Feature Name'
                        data-dtype='String'
                        style='flex: 1;'
                      />
                      <a
                        class='item-control'
                        data-action='removeLevelFeature'
                        data-feature-index='{{feature.index}}'
                        data-tooltip='Remove Feature'
                      >
                        <i class='fas fa-trash'></i>
                      </a>
                    </div>
                    <input
                      type='text'
                      name='system.levelFeatures.{{feature.index}}.description'
                      value='{{feature.description}}'
                      placeholder='Feature description...'
                      data-dtype='String'
                      style='width: 100%;'
                    />
                    <input
                      type='hidden'
                      name='system.levelFeatures.{{feature.index}}.level'
                      value='{{feature.level}}'
                    />
                  {{else}}
                    <strong>{{feature.name}}</strong>
                    {{#if feature.description}}
                      <div style='margin-top: 5px;'>{{feature.description}}</div>
                    {{/if}}
                  {{/if}}
                </div>
              </li>
            {{/each}}
          </ol>
        {{else}}
          <p style='margin: 0; font-style: italic; color: #666;'>
            No features at this level.{{#if @root.editable}} Click "Add Feature" to add one.{{/if}}
          </p>
        {{/if}}
      </div>
    {{/each}}
  </div>
</section>
