{{! Ancestry Details Tab - Fixed button styling }}
<section
  class='tab details {{tab.cssClass}}'
  data-group='primary'
  data-tab='details'
>
  {{! Ancestry Basic Info - Using existing grid-2col class }}
  <div class='grid-2col'>
    <div class='resource'>
      <label class='resource-label'>{{localize 'VAGABOND.Item.Ancestry.FIELDS.size.label'}}</label>
      <select name='system.size' data-dtype='String'>
        <option value='tiny' {{#if (eq system.size 'tiny')}}selected{{/if}}>Tiny</option>
        <option value='small' {{#if (eq system.size 'small')}}selected{{/if}}>Small</option>
        <option value='medium' {{#if (eq system.size 'medium')}}selected{{/if}}>Medium</option>
        <option value='large' {{#if (eq system.size 'large')}}selected{{/if}}>Large</option>
        <option value='huge' {{#if (eq system.size 'huge')}}selected{{/if}}>Huge</option>
        <option value='gargantuan' {{#if (eq system.size 'gargantuan')}}selected{{/if}}>Gargantuan</option>
      </select>
    </div>
    <div class='resource'>
      <label class='resource-label'>{{localize 'VAGABOND.Item.Ancestry.FIELDS.ancestryType.label'}}</label>
      <select name='system.ancestryType' data-dtype='String'>
        <option value='Humanlike' {{#if (eq system.ancestryType 'Humanlike')}}selected{{/if}}>Humanlike</option>
        <option value='Fae' {{#if (eq system.ancestryType 'Fae')}}selected{{/if}}>Fae</option>
        <option value='Cryptid' {{#if (eq system.ancestryType 'Cryptid')}}selected{{/if}}>Cryptid</option>
        <option value='Artificials' {{#if (eq system.ancestryType 'Artificials')}}selected{{/if}}>Artificials</option>
        <option value='Beasts' {{#if (eq system.ancestryType 'Beasts')}}selected{{/if}}>Beasts</option>
        <option value='Outers' {{#if (eq system.ancestryType 'Outers')}}selected{{/if}}>Outers</option>
        <option value='Primordials' {{#if (eq system.ancestryType 'Primordials')}}selected{{/if}}>Primordials</option>
        <option value='Undead' {{#if (eq system.ancestryType 'Undead')}}selected{{/if}}>Undead</option>
      </select>
    </div>
  </div>

  {{! Description Section }}
  <div style='margin: 10px 0;'>
    <label class='resource-label'>Description</label>
    {{#if editable}}
      <prose-mirror name="system.description" data-document-uuid="{{item.uuid}}" value="{{system.description}}" collaborate="true" toggled="true">
        {{{enrichedDescription}}}
      </prose-mirror>
    {{else}} 
      {{{enrichedDescription}}}
    {{/if}}
  </div>

  {{! Traits Section - Fixed button styling }}
  <div style='margin: 10px 0 0.5rem 0;'>
    <div class='items-header'>
      <div class='item-name'>Traits</div>
      {{#if editable}}
        <div class='item-controls'>
          <button 
            type='button'
            class='item-control'
            data-action='addTrait'
            data-tooltip='Add New Trait'
            style='background: none; border: none; color: inherit; cursor: pointer; font-size: 12px; padding: 0;'
          >
            <i class='fas fa-plus'></i>
          </button>
        </div>
      {{/if}}
    </div>
    
    {{! Traits list with proper height management }}
    <ol class='items-list' style='max-height: 150px; margin-bottom: 0.5rem;'>
      {{#if system.traits.length}}
        {{#each system.traits as |trait index|}}
          <li class='item' data-trait-index='{{index}}' style='display: block; padding: 5px;'>
            {{#if @root.editable}}
              <div style='display: flex; align-items: center; margin-bottom: 3px;'>
                <input
                  type='text'
                  name='system.traits.{{index}}.name'
                  value='{{trait.name}}'
                  placeholder='Trait Name'
                  data-dtype='String'
                  style='flex: 1; margin-right: 8px; padding: 2px 4px; font-size: 13px; font-weight: bold;'
                />
                <button 
                  type='button'
                  class='item-control'
                  data-action='removeTrait'
                  data-trait-index='{{index}}'
                  data-tooltip='Remove Trait'
                  style='background: none; border: none; color: inherit; cursor: pointer; font-size: 12px; padding: 0;'
                >
                  <i class='fas fa-trash'></i>
                </button>
              </div>
              <input
                type="text"
                name='system.traits.{{index}}.description'
                value='{{trait.description}}'
                placeholder='Trait description...'
                data-dtype='String'
                style='width: 100%; padding: 2px 4px; font-size: 12px;'
              />
            {{else}}
              <div class='item-name'>
                <strong>{{trait.name}}</strong>
              </div>
              <div style='font-size: 12px; margin-top: 2px; color: var(--vagabond-c-tan);'>{{trait.description}}</div>
            {{/if}}
          </li>
        {{/each}}
      {{else}}
        <li style='text-align: center; color: var(--vagabond-c-tan); font-style: italic; padding: 20px; font-size: 12px;'>
          No traits defined.{{#if editable}} Click the + button to add one.{{/if}}
        </li>
      {{/if}}
    </ol>
  </div>
</section>
