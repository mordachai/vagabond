              <i class='fas fa-plus'></i> {{localize 'VAGABOND.Status.AddPassiveEffect'}}
            </button>
          </div>
        </details>
      </div>

      {{! ===== ARMOR-SPECIFIC FIELDS ===== }}
      {{#if (eq system.equipmentType 'armor')}}
        <div class="item-section-box">
          <div class="item-section-label">{{localize "VAGABOND.UI.Sections.ArmorConfig"}}</div>
