          </label>
          <label class='checkbox-label'>
            <input type='checkbox' name='system.isConsumable' {{#if system.isConsumable}}checked{{/if}} data-dtype='Boolean'/>
            <span>Consumable (reduces quantity on use)</span>
          </label>
          <label class='checkbox-label'>
            <input type='checkbox' name='system.isBeverage' {{#if system.isBeverage}}checked{{/if}} data-dtype='Boolean'/>
            <span>{{localize 'VAGABOND.Item.Equipment.IsBeverage'}}</span>
          </label>
          <div class='linked-consumable-field'>
            <select name='system.linkedConsumable' data-dtype='String' data-tooltip='{{localize "VAGABOND.Item.Equipment.LinkedConsumableHint"}}'>
              <option value=''>{{localize "VAGABOND.Item.Equipment.LinkedConsumableNone"}}</option>
              {{#each actorConsumableItems as |consumable|}}
                <option value='{{consumable.id}}' {{#if (eq ../system.linkedConsumable consumable.id)}}selected{{/if}}>
                  {{consumable.name}} ({{consumable.system.quantity}} remaining)
                </option>
              {{/each}}
            </select>
          </div>
        </div>
      </div>

      {{! ===== STATUS PROTECTIONS (armor only) ===== }}
      {{#if (eq system.equipmentType 'armor')}}
        <details class='item-section-details' data-details-id='status-protections'>
          <summary class='item-section-summary'>
            <i class='fas fa-chevron-right accordion-icon'></i>
            <span>{{localize 'VAGABOND.Status.StatusProtections'}}</span>
          </summary>
          <div class='status-protections-body'>
            <div class='status-protect-col'>
              <p class='status-protect-heading'>{{localize 'VAGABOND.Status.Blocks'}}</p>
              {{#each @root.config.statusConditions as |label key|}}
                <label class='npc-immunity-checkbox-item'>
                  <input type='checkbox' data-action='toggleBlockedStatus' data-status-id='{{key}}'
                    {{#if (contains ../system.blockedStatuses key)}}checked{{/if}}>
                  <span>{{localize label}}</span>
                </label>
              {{/each}}
            </div>
            <div class='status-protect-col'>
              <p class='status-protect-heading'>{{localize 'VAGABOND.Status.Resists'}}</p>
              {{#each @root.config.statusConditions as |label key|}}
                <label class='npc-immunity-checkbox-item'>
                  <input type='checkbox' data-action='toggleResistedStatus' data-status-id='{{key}}'
                    {{#if (contains ../system.resistedStatuses key)}}checked{{/if}}>
                  <span>{{localize label}}</span>
                </label>
              {{/each}}
            </div>
          </div>
        </details>
      {{/if}}

      {{! ===== SEQUENCER FX (weapons, alchemicals, relics only) ===== }}
      {{#if sequencerAvailable}}
        {{#if (or (eq system.equipmentType 'weapon') (eq system.equipmentType 'alchemical') (eq system.equipmentType 'relic'))}}
          <details class='item-fx-details' data-details-id='item-fx-section'>
            <summary class='item-fx-summary'>
              <i class='fas fa-chevron-down'></i>
              <span>Item FX <small>(Sequencer)</small></span>
              {{#if system.itemFx.enabled}}<span class='item-fx-active-badge'>ON</span>{{/if}}
            </summary>
            <div class='item-fx-section'>
              <div class='form-group'>
                <label class='checkbox-label'>
                  <input type='checkbox' name='system.itemFx.enabled' {{#if system.itemFx.enabled}}checked{{/if}} data-dtype='Boolean'>
                  <span>Enable Animation</span>
                </label>
              </div>

              {{! Animation type selector — only for non-weapons (weapons auto-derive from weapon skill) }}
              {{#unless isWeapon}}
                <div class='form-group'>
                  <label class='resource-label'>Animation Type</label>
                  <select name='system.itemFx.animType' data-dtype='String'>
                    <option value='melee' {{#if (eq system.itemFx.animType 'melee')}}selected{{/if}}>Melee — impact at target</option>
                    <option value='ranged' {{#if (eq system.itemFx.animType 'ranged')}}selected{{/if}}>Ranged — beam to target</option>
                  </select>
                </div>
              {{/unless}}

              <fieldset class='item-fx-group'>
                <legend>Hit Animation</legend>
                <div class='item-fx-file-row'>
                  <input type='text' name='system.itemFx.hitFile' value='{{system.itemFx.hitFile}}' placeholder='path/Weapon* or anim01.webm | anim02.webm' data-dtype='String'>
                  <button type='button' class='item-fx-browse-btn' data-action='browseItemFxFile' data-field='system.itemFx.hitFile' data-tooltip='Browse video file'>
                    <i class='fas fa-film'></i>
                  </button>
                </div>
                <div class='item-fx-scale-row'>
                  <label class='resource-label'>Scale</label>
                  <input type='number' name='system.itemFx.hitScale' value='{{system.itemFx.hitScale}}' min='0.1' step='0.1' data-dtype='Number'>
                  <label class='resource-label'>Offset X</label>
                  <input type='number' name='system.itemFx.hitOffsetX' value='{{system.itemFx.hitOffsetX}}' step='10' data-dtype='Number'>
                  <label class='resource-label'>Duration (ms)</label>
                  <input type='number' name='system.itemFx.hitDuration' value='{{system.itemFx.hitDuration}}' min='100' step='50' data-dtype='Number'>
                </div>
                <div class='item-fx-file-row'>
                  <input type='text' name='system.itemFx.hitSound' value='{{system.itemFx.hitSound}}' placeholder='path/to/hit.ogg (optional)' data-dtype='String'>
                  <button type='button' class='item-fx-browse-btn' data-action='browseItemFxSound' data-field='system.itemFx.hitSound' data-tooltip='Browse audio file'>
                    <i class='fas fa-music'></i>
                  </button>
                </div>
              </fieldset>

              <fieldset class='item-fx-group'>
                <legend>Miss Animation <span class='item-fx-hint'>(optional — plays on attacker)</span></legend>
                <div class='item-fx-file-row'>
                  <input type='text' name='system.itemFx.missFile' value='{{system.itemFx.missFile}}' placeholder='path/Miss* or miss01.webm | miss02.webm  (optional)' data-dtype='String'>
                  <button type='button' class='item-fx-browse-btn' data-action='browseItemFxFile' data-field='system.itemFx.missFile' data-tooltip='Browse video file'>
                    <i class='fas fa-film'></i>
                  </button>
                </div>
                <div class='item-fx-scale-row'>
                  <label class='resource-label'>Scale</label>
                  <input type='number' name='system.itemFx.missScale' value='{{system.itemFx.missScale}}' min='0.1' step='0.1' data-dtype='Number'>
                  <label class='resource-label'>Duration (ms)</label>
                  <input type='number' name='system.itemFx.missDuration' value='{{system.itemFx.missDuration}}' min='100' step='50' data-dtype='Number'>
                </div>
                <div class='item-fx-file-row'>
                  <input type='text' name='system.itemFx.missSound' value='{{system.itemFx.missSound}}' placeholder='path/to/miss.ogg (optional)' data-dtype='String'>
                  <button type='button' class='item-fx-browse-btn' data-action='browseItemFxSound' data-field='system.itemFx.missSound' data-tooltip='Browse audio file'>
                    <i class='fas fa-music'></i>
                  </button>
                </div>
              </fieldset>

              <div class='item-fx-scale-row'>
                <label class='resource-label'>Sound Volume</label>
                <input type='number' name='system.itemFx.soundVolume' value='{{system.itemFx.soundVolume}}' min='0' max='1' step='0.05' data-dtype='Number'>
                <span class='item-fx-hint'>0 – 1 (applies to both sounds)</span>
              </div>
            </div>
          </details>
        {{/if}}
      {{/if}}
    </div>
  {{/if}}
</section>
