{{! Spell Details Tab }}
<section
  class='tab details {{tab.cssClass}}'
  data-group='primary'
  data-tab='details'
>
  <div class='spell-item-content'>
    {{! Description Section }}
    <div>
      <label class='resource-label'>{{localize 'VAGABOND.Item.Spell.FIELDS.description.label'}}</label>
      <div class='spell-description'>
        {{#if editable}}
          <prose-mirror name="system.description" data-document-uuid="{{item.uuid}}" value="{{system.description}}" collaborate="true" toggled="true">
            {{{enriched.description}}}
          </prose-mirror>
        {{else}}
          <div>{{{enriched.description}}}</div>
        {{/if}}
      </div>
    </div>

    {{! Damage Base and Duration - Same Line }}
    <div class='flexrow gap-8'>
      <div class='form-group flex-1'>
        <label class='resource-label'>{{localize 'VAGABOND.Item.Spell.FIELDS.damageBase.label'}}</label>
        <select name='system.damageBase'>
          <option value='-' {{#if (eq system.damageBase '-')}}selected{{/if}}>{{localize 'VAGABOND.DamageTypes.None'}}</option>
          <option value='acid' {{#if (eq system.damageBase 'acid')}}selected{{/if}}>{{localize 'VAGABOND.DamageTypes.Acid'}}</option>
          <option value='fire' {{#if (eq system.damageBase 'fire')}}selected{{/if}}>{{localize 'VAGABOND.DamageTypes.Fire'}}</option>
          <option value='shock' {{#if (eq system.damageBase 'shock')}}selected{{/if}}>{{localize 'VAGABOND.DamageTypes.Shock'}}</option>
          <option value='poison' {{#if (eq system.damageBase 'poison')}}selected{{/if}}>{{localize 'VAGABOND.DamageTypes.Poison'}}</option>
          <option value='cold' {{#if (eq system.damageBase 'cold')}}selected{{/if}}>{{localize 'VAGABOND.DamageTypes.Cold'}}</option>
          <option value='blunt' {{#if (eq system.damageBase 'blunt')}}selected{{/if}}>{{localize 'VAGABOND.DamageTypes.Blunt'}}</option>
          <option value='physical' {{#if (eq system.damageBase 'physical')}}selected{{/if}}>{{localize 'VAGABOND.DamageTypes.Physical'}}</option>
          <option value='necrotic' {{#if (eq system.damageBase 'necrotic')}}selected{{/if}}>{{localize 'VAGABOND.DamageTypes.Necrotic'}}</option>
        </select>
      </div>
      <div class='form-group flex-2'>
        <label class='resource-label'>{{localize 'VAGABOND.Item.Spell.FIELDS.duration.label'}}</label>
        <input
          type='text'
          name='system.duration'
          value='{{system.duration}}'
          placeholder='{{localize "VAGABOND.Item.Spell.FIELDS.duration.hint"}}'
        />
      </div>
    </div>

    {{! Note about delivery selection }}
    <div class='form-group'>
      <p class='hint-text'><em>Note: Delivery type, cost, and range are selected when casting the spell from your favorited spells.</em></p>
    </div>

    {{! Crit }}
    <div class='form-group'>
      <label class='resource-label'>{{localize 'VAGABOND.Item.Spell.FIELDS.crit.label'}}</label>
      <input
        type='text'
        name='system.crit'
        value='{{system.crit}}'
        placeholder='{{localize "VAGABOND.Item.Spell.FIELDS.crit.hint"}}'
      />
    </div>
  </div>
</section>
