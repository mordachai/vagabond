{{! Party Tab — supplies bar + member card grid }}
<section
  class="tab party scrollable {{tab.cssClass}}"
  data-group="primary"
  data-tab="party"
>

  {{! ── Party Header ─────────────────────────────────────────────────────── }}
  <div class="party-header">
    <img
      class="party-portrait"
      src="{{actor.img}}"
      alt="{{actor.name}}"
      data-edit="img"
      data-action="onEditImage"
      data-tooltip="{{actor.name}}"
    >
    <div class="party-info">
      <input
        type="text"
        name="name"
        value="{{actor.name}}"
        class="party-name"
        placeholder="{{localize 'VAGABOND.Actor.Party.NamePlaceholder'}}"
      >
      <input
        type="text"
        name="system.type"
        value="{{system.type}}"
        class="party-type"
        placeholder="{{localize 'VAGABOND.Actor.Party.TypePlaceholder'}}"
      >
      <div class="party-speeds">
        <div class="party-speed-stat">
          <span class="speed-label">{{localize 'VAGABOND.Actor.Character.FIELDS.combat.speed.base.label'}}:</span>
          <input type="number" name="system.speed" value="{{system.speed}}" class="speed-input" min="0">
          <span class="speed-unit">{{localize 'VAGABOND.UI.Units.Feet'}}</span>
        </div>
        <div class="party-speed-stat">
          <span class="speed-label">{{localize 'VAGABOND.Actor.Character.FIELDS.combat.speed.crawl.label'}}:</span>
          <input type="number" name="system.crawl" value="{{system.crawl}}" class="speed-input" min="0">
          <span class="speed-unit">{{localize 'VAGABOND.UI.Units.Feet'}}</span>
        </div>
        <div class="party-speed-stat">
          <span class="speed-label">{{localize 'VAGABOND.Actor.Character.FIELDS.combat.speed.travel.label'}}:</span>
          <input type="number" name="system.travel" value="{{system.travel}}" class="speed-input" min="0">
          <span class="speed-unit">{{localize 'VAGABOND.UI.Units.Miles'}}</span>
        </div>
      </div>
    </div>
  </div>

  {{! ── Supplies Bar ───────────────────────────────────── }}
  <div class="party-supplies-bar">
    <span class="supplies-label"><i class="fa-sharp fa-regular fa-wheat"></i> {{localize 'VAGABOND.Actor.Party.Card.Rations'}}: </span>
    <span class="supplies-value">{{supplies.rations}}</span>
    <span class="supplies-sep">·</span>
    <span class="supplies-label"><i class="fa-solid fa-droplet"></i> {{localize 'VAGABOND.Actor.Party.Card.Beverages'}}: </span>
    <span class="supplies-value">{{supplies.beverages}}</span>

    <span class="supplies-wealth">
      <i class="fas fa-coins" data-tooltip="{{localize 'VAGABOND.Actor.Party.Card.TotalWealth'}}"></i>
      <span class="supplies-value" data-tooltip="{{localize 'VAGABOND.Wealth.Gold'}}">{{supplies.currency.gold}}<span class="currency-abbr">{{localize 'VAGABOND.Currency.Gold.abbr'}}</span></span>
      <span class="supplies-value" data-tooltip="{{localize 'VAGABOND.Wealth.Silver'}}">{{supplies.currency.silver}}<span class="currency-abbr">{{localize 'VAGABOND.Currency.Silver.abbr'}}</span></span>
      <span class="supplies-value" data-tooltip="{{localize 'VAGABOND.Wealth.Copper'}}">{{supplies.currency.copper}}<span class="currency-abbr">{{localize 'VAGABOND.Currency.Copper.abbr'}}</span></span>
    </span>
  </div>

  {{! ── Member Management Header ──────────────────────── }}
  <div class="party-members-header">
    {{#if isGM}}
    <button
      type="button"
      class="party-compact-view-btn"
      data-action="openCompactView"
      data-tooltip="{{localize 'VAGABOND.Actor.Party.CompactView.Open'}}"
    >
      <i class="fas fa-table-columns"></i>
      {{localize 'VAGABOND.Actor.Party.CompactView.Open'}}
    </button>
    {{/if}}
    <button
      type="button"
      class="party-add-member"
      data-action="openMemberPicker"
      data-tooltip="{{localize 'VAGABOND.Actor.Party.Card.AddMember'}}"
    >
      <i class="fas fa-user-plus"></i>
      {{localize 'VAGABOND.Actor.Party.Card.AddMember'}}
    </button>
  </div>

  {{! ── Member Card Grid ───────────────────────────────── }}
  {{#if members.length}}
    <div class="party-member-grid" style="--member-count: {{members.length}}">
      {{#each members}}
        {{#if isNPC}}
          {{> "systems/vagabond/templates/party/party-npc-card.hbs" config=../config}}
        {{else}}
          {{> "systems/vagabond/templates/party/party-member-card.hbs"}}
        {{/if}}
      {{/each}}
    </div>
  {{else}}
    <div class="party-empty-state">
      <p>{{localize 'VAGABOND.Actor.Party.Card.NoMembers'}}</p>
      <p class="hint">{{localize 'VAGABOND.Actor.Party.Card.NoMembersHint'}}</p>
    </div>
  {{/if}}

</section>
